<!--
    PersonalAI / Aeda — Theme Resources (v2)
    ==========================================
    Dark, colorful, flat-tint design system.

    Design language: a deep near-black canvas with genuinely saturated,
    flat-tinted module cards — not a single gray repeated everywhere, and not
    gradients (flat fills only, by design, for predictable WinUI rendering).
    Each module on the dashboard gets its own identity color so the grid reads
    at a glance instead of all tiles looking interchangeable.

    CONTRACT: every key referenced by MainWindow.xaml via {ThemeResource} or
    {StaticResource} is defined below. No key has been renamed or removed
    relative to the original app — only values changed, plus new ADDITIVE
    resources (module accent brushes + converter) for the dashboard.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters">

    <!-- ============================================================
         THEME DICTIONARIES
         ============================================================ -->
    <ResourceDictionary.ThemeDictionaries>

        <!-- ==== DARK (primary/default experience) ==== -->
        <ResourceDictionary x:Key="Default">

            <!-- Core accent — saturated violet, the Aeda "Watcher" mark color -->
            <Color x:Key="PersonalAiAccentColor">#7C6CF0</Color>
            <Color x:Key="PersonalAiAccentColorLight">#9B8CFF</Color>
            <Color x:Key="PersonalAiAccentColorDark">#5E4FD1</Color>
            <SolidColorBrush x:Key="PersonalAiAccentBrush" Color="{StaticResource PersonalAiAccentColor}" />

            <!-- Canvas: deep near-black, not pure black, with a faint violet cast -->
            <SolidColorBrush x:Key="PersonalAiPageBackgroundBrush" Color="#13131A" />
            <SolidColorBrush x:Key="PersonalAiSidebarBackgroundBrush" Color="#1B1B24" />

            <!-- Elevated surface = cards, message bubbles, composer -->
            <SolidColorBrush x:Key="PersonalAiElevatedSurfaceBrush" Color="#1F1F2A" />
            <SolidColorBrush x:Key="PersonalAiSubtleSurfaceBrush" Color="#252531" />
            <SolidColorBrush x:Key="PersonalAiHoverSurfaceBrush" Color="#2C2C3A" />
            <SolidColorBrush x:Key="PersonalAiPressedSurfaceBrush" Color="#34344880" />

            <!-- Selected / active state -->
            <SolidColorBrush x:Key="PersonalAiActiveBrush" Color="#2D2A52" />
            <SolidColorBrush x:Key="PersonalAiActiveBorderBrush" Color="#5E4FD1" />

            <!-- Hairline borders -->
            <SolidColorBrush x:Key="PersonalAiBorderBrush" Color="#2A2A36" />
            <SolidColorBrush x:Key="PersonalAiStrongBorderBrush" Color="#3A3A4A" />

            <!-- Typography -->
            <SolidColorBrush x:Key="PersonalAiPrimaryTextBrush" Color="#F2F1F8" />
            <SolidColorBrush x:Key="PersonalAiSecondaryTextBrush" Color="#A8A6BC" />
            <SolidColorBrush x:Key="PersonalAiMutedTextBrush" Color="#75748C" />
            <SolidColorBrush x:Key="PersonalAiAccentTextBrush" Color="#C9C4FF" />

            <SolidColorBrush x:Key="AedaAssistGlassBrush" Color="#E61B1A27" />
            <SolidColorBrush x:Key="AedaAssistBorderBrush" Color="#665E55A0" />
            <SolidColorBrush x:Key="AedaAssistForegroundBrush" Color="#F5F3FF" />
            <SolidColorBrush x:Key="AedaAssistSecondaryForegroundBrush" Color="#AAA6C5" />

            <!-- Chat role surfaces -->
            <SolidColorBrush x:Key="PersonalAiUserBubbleBrush" Color="#2D2A52" />
            <SolidColorBrush x:Key="PersonalAiAssistantBubbleBrush" Color="#1F1F2A" />

            <SolidColorBrush x:Key="PersonalAiDangerBrush" Color="#F0958F" />
            <SolidColorBrush x:Key="PersonalAiSuccessBrush" Color="#7FE0B0" />
            <SolidColorBrush x:Key="PersonalAiWarningBrush" Color="#F0D898" />
            <SolidColorBrush x:Key="PersonalAiErrorBrush" Color="#F0958F" />
            <SolidColorBrush x:Key="PersonalAiMessageSurfaceBrush" Color="#1F1F2A" />
            <SolidColorBrush x:Key="PersonalAiToolActivitySurfaceBrush" Color="#252531" />
            <SolidColorBrush x:Key="PersonalAiCodeBackgroundBrush" Color="#13131A" />
            <SolidColorBrush x:Key="PersonalAiCodeHeaderBrush" Color="#252531" />

            <!-- ===== MODULE ACCENT BRUSHES (additive, flat-tint per module) =====
                 Each pair = a card background + a matching foreground/icon color
                 at a contrast ratio that stays readable on the dark fill. Used
                 by ModuleAccentBrushConverter, keyed off ModuleTile.DisplayName. -->
            <SolidColorBrush x:Key="PersonalAiModuleCodeFillBrush" Color="#2D2A52" />
            <SolidColorBrush x:Key="PersonalAiModuleCodeForegroundBrush" Color="#C9C4FF" />
            <SolidColorBrush x:Key="PersonalAiModuleCodeBorderBrush" Color="#3D3A66" />

            <SolidColorBrush x:Key="PersonalAiModuleMemoryFillBrush" Color="#1E4A45" />
            <SolidColorBrush x:Key="PersonalAiModuleMemoryForegroundBrush" Color="#8FE3C4" />
            <SolidColorBrush x:Key="PersonalAiModuleMemoryBorderBrush" Color="#2C6359" />

            <SolidColorBrush x:Key="PersonalAiModuleResearchFillBrush" Color="#23344A" />
            <SolidColorBrush x:Key="PersonalAiModuleResearchForegroundBrush" Color="#8FB8E8" />
            <SolidColorBrush x:Key="PersonalAiModuleResearchBorderBrush" Color="#324C68" />

            <SolidColorBrush x:Key="PersonalAiModuleClawFillBrush" Color="#4A2D2D" />
            <SolidColorBrush x:Key="PersonalAiModuleClawForegroundBrush" Color="#F0A89B" />
            <SolidColorBrush x:Key="PersonalAiModuleClawBorderBrush" Color="#663E3E" />

            <SolidColorBrush x:Key="PersonalAiModulePicStudioFillBrush" Color="#4A2D5C" />
            <SolidColorBrush x:Key="PersonalAiModulePicStudioForegroundBrush" Color="#E0B8F0" />
            <SolidColorBrush x:Key="PersonalAiModulePicStudioBorderBrush" Color="#5E3B73" />

            <SolidColorBrush x:Key="PersonalAiModuleOfficeFillBrush" Color="#3D3318" />
            <SolidColorBrush x:Key="PersonalAiModuleOfficeForegroundBrush" Color="#F0D898" />
            <SolidColorBrush x:Key="PersonalAiModuleOfficeBorderBrush" Color="#564A22" />

            <SolidColorBrush x:Key="PersonalAiModuleVoiceFillBrush" Color="#1E3A4A" />
            <SolidColorBrush x:Key="PersonalAiModuleVoiceForegroundBrush" Color="#92C9E8" />
            <SolidColorBrush x:Key="PersonalAiModuleVoiceBorderBrush" Color="#2C5266" />

            <!-- Fallback for any module name the converter doesn't recognize —
                 same as the plain elevated surface, so unknown modules degrade
                 gracefully instead of erroring. -->
            <SolidColorBrush x:Key="PersonalAiModuleDefaultFillBrush" Color="#1F1F2A" />
            <SolidColorBrush x:Key="PersonalAiModuleDefaultForegroundBrush" Color="#C9C4FF" />
            <SolidColorBrush x:Key="PersonalAiModuleDefaultBorderBrush" Color="#2A2A36" />
        </ResourceDictionary>

        <!-- ==== LIGHT ==== -->
        <ResourceDictionary x:Key="Light">

            <Color x:Key="PersonalAiAccentColor">#5746C2</Color>
            <Color x:Key="PersonalAiAccentColorLight">#7164D6</Color>
            <Color x:Key="PersonalAiAccentColorDark">#453592</Color>
