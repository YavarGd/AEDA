            <SolidColorBrush x:Key="PersonalAiPageBackgroundBrush" Color="#F4F4F2" />
            <SolidColorBrush x:Key="PersonalAiSidebarBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="PersonalAiElevatedSurfaceBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="PersonalAiSubtleSurfaceBrush" Color="#F4F4F2" />
            <SolidColorBrush x:Key="PersonalAiHoverSurfaceBrush" Color="#ECEBE7" />
            <SolidColorBrush x:Key="PersonalAiPressedSurfaceBrush" Color="#DEDDD7" />

            <SolidColorBrush x:Key="PersonalAiActiveBrush" Color="#EEF0FF" />
            <SolidColorBrush x:Key="PersonalAiActiveBorderBrush" Color="#5746C2" />

            <SolidColorBrush x:Key="PersonalAiBorderBrush" Color="#EBEAE6" />
            <SolidColorBrush x:Key="PersonalAiStrongBorderBrush" Color="#DEDDD7" />

            <SolidColorBrush x:Key="PersonalAiPrimaryTextBrush" Color="#18181B" />
            <SolidColorBrush x:Key="PersonalAiSecondaryTextBrush" Color="#75746E" />
            <SolidColorBrush x:Key="PersonalAiMutedTextBrush" Color="#9B9A95" />
            <SolidColorBrush x:Key="PersonalAiAccentTextBrush" Color="#453592" />

            <SolidColorBrush x:Key="AedaAssistGlassBrush" Color="#E6FCFBFF" />
            <SolidColorBrush x:Key="AedaAssistBorderBrush" Color="#665746C2" />
            <SolidColorBrush x:Key="AedaAssistForegroundBrush" Color="#18171D" />
            <SolidColorBrush x:Key="AedaAssistSecondaryForegroundBrush" Color="#696775" />

            <SolidColorBrush x:Key="PersonalAiUserBubbleBrush" Color="#EEF0FF" />
            <SolidColorBrush x:Key="PersonalAiAssistantBubbleBrush" Color="#F4F4F2" />

            <SolidColorBrush x:Key="PersonalAiDangerBrush" Color="#C4314B" />
            <SolidColorBrush x:Key="PersonalAiSuccessBrush" Color="#1A8F5C" />
            <SolidColorBrush x:Key="PersonalAiWarningBrush" Color="#8A6914" />
            <SolidColorBrush x:Key="PersonalAiErrorBrush" Color="#C4314B" />
            <SolidColorBrush x:Key="PersonalAiMessageSurfaceBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="PersonalAiToolActivitySurfaceBrush" Color="#F4F4F2" />
            <SolidColorBrush x:Key="PersonalAiCodeBackgroundBrush" Color="#F4F4F2" />
            <SolidColorBrush x:Key="PersonalAiCodeHeaderBrush" Color="#ECEBE7" />

            <SolidColorBrush x:Key="PersonalAiModuleCodeFillBrush" Color="#EEF0FF" />
            <SolidColorBrush x:Key="PersonalAiModuleCodeForegroundBrush" Color="#453592" />
            <SolidColorBrush x:Key="PersonalAiModuleCodeBorderBrush" Color="#D4D3F5" />

            <SolidColorBrush x:Key="PersonalAiModuleMemoryFillBrush" Color="#E5F6EF" />
            <SolidColorBrush x:Key="PersonalAiModuleMemoryForegroundBrush" Color="#15694B" />
            <SolidColorBrush x:Key="PersonalAiModuleMemoryBorderBrush" Color="#BFE8D6" />

            <SolidColorBrush x:Key="PersonalAiModuleResearchFillBrush" Color="#E8F0FB" />
            <SolidColorBrush x:Key="PersonalAiModuleResearchForegroundBrush" Color="#1D5499" />
            <SolidColorBrush x:Key="PersonalAiModuleResearchBorderBrush" Color="#C5DCF2" />

            <SolidColorBrush x:Key="PersonalAiModuleClawFillBrush" Color="#FBEEEC" />
            <SolidColorBrush x:Key="PersonalAiModuleClawForegroundBrush" Color="#9C3B2E" />
            <SolidColorBrush x:Key="PersonalAiModuleClawBorderBrush" Color="#F0D2CC" />

            <SolidColorBrush x:Key="PersonalAiModulePicStudioFillBrush" Color="#F6ECFA" />
            <SolidColorBrush x:Key="PersonalAiModulePicStudioForegroundBrush" Color="#7B3A93" />
            <SolidColorBrush x:Key="PersonalAiModulePicStudioBorderBrush" Color="#E5CCF0" />

            <SolidColorBrush x:Key="PersonalAiModuleOfficeFillBrush" Color="#FBF3DF" />
            <SolidColorBrush x:Key="PersonalAiModuleOfficeForegroundBrush" Color="#8A6914" />
            <SolidColorBrush x:Key="PersonalAiModuleOfficeBorderBrush" Color="#F0DFAE" />

            <SolidColorBrush x:Key="PersonalAiModuleVoiceFillBrush" Color="#E8F3FA" />
            <SolidColorBrush x:Key="PersonalAiModuleVoiceForegroundBrush" Color="#1D6694" />
            <SolidColorBrush x:Key="PersonalAiModuleVoiceBorderBrush" Color="#C5E2F0" />

            <SolidColorBrush x:Key="PersonalAiModuleDefaultFillBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="PersonalAiModuleDefaultForegroundBrush" Color="#453592" />
            <SolidColorBrush x:Key="PersonalAiModuleDefaultBorderBrush" Color="#EBEAE6" />
        </ResourceDictionary>

        <!-- ==== HIGH CONTRAST — system fallback, unchanged in intent ==== -->
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="PersonalAiAccentBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="PersonalAiPageBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiSidebarBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiElevatedSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiSubtleSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiHoverSurfaceBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="PersonalAiPressedSurfaceBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="PersonalAiActiveBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="PersonalAiActiveBorderBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="PersonalAiBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiStrongBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiPrimaryTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiSecondaryTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiMutedTextBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
            <SolidColorBrush x:Key="PersonalAiAccentTextBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AedaAssistGlassBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="AedaAssistBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AedaAssistForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AedaAssistSecondaryForegroundBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
            <SolidColorBrush x:Key="PersonalAiUserBubbleBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="PersonalAiAssistantBubbleBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiDangerBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiSuccessBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiWarningBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiErrorBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiMessageSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiToolActivitySurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiCodeBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiCodeHeaderBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleCodeFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleCodeForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleCodeBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleMemoryFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleMemoryForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleMemoryBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleResearchFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleResearchForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleResearchBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleClawFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleClawForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleClawBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModulePicStudioFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiModulePicStudioForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModulePicStudioBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleOfficeFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleOfficeForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleOfficeBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleVoiceFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleVoiceForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleVoiceBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleDefaultFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleDefaultForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PersonalAiModuleDefaultBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
