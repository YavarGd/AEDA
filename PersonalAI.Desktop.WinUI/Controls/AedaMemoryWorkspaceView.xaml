<UserControl x:Class="PersonalAI.Desktop.WinUI.Controls.AedaMemoryWorkspaceView"
    x:Name="MemoryWorkspace"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters">
    <UserControl.Resources><converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" /></UserControl.Resources>
    <ScrollViewer>
        <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Style="{StaticResource PersonalAiStatusPillStyle}"><TextBlock Text="Local only" /></Border>
                <Border Style="{StaticResource PersonalAiStatusPillStyle}"><TextBlock Text="Explicit memory" /></Border>
                <Border Style="{StaticResource PersonalAiStatusPillStyle}"><TextBlock Text="Automatic memory disabled" /></Border>
            </StackPanel>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.15*"/><ColumnDefinition Width="0.85*"/></Grid.ColumnDefinitions>
                <StackPanel Spacing="12">
                    <Border Style="{StaticResource PersonalAiWorkspaceCardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Memory overview" Style="{StaticResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="{Binding TotalMemoryCountText}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{Binding IndexedKnowledgeText}" Style="{StaticResource PersonalAiSecondaryTextStyle}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding RetrievalStatusText}" VerticalAlignment="Center"
                                       Style="{StaticResource PersonalAiMetadataTextStyle}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource PersonalAiWorkspaceCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Search memories" Style="{StaticResource PersonalAiSectionTitleTextStyle}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox PlaceholderText="Search memories" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Search memories" />
                                <Button Grid.Column="1" Content="Search" Command="{Binding SearchMemoriesCommand}" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate><DataTemplate>
                                    <Button HorizontalContentAlignment="Stretch" Margin="0,0,0,6"
                                            Command="{Binding DataContext.OpenMemoryDetailCommand, ElementName=MemoryWorkspace}" CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding PreviewText}" TextTrimming="CharacterEllipsis" />
                                    </Button>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PersonalAiWorkspaceCardStyle}">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Recent memories" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="No explicit memories yet." Style="{StaticResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoRecentMemories, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding Dashboard.RecentMemories}">
                                    <ItemsControl.ItemTemplate><DataTemplate>
                                        <Button HorizontalContentAlignment="Stretch" Margin="0,0,0,6"
                                                Command="{Binding DataContext.OpenMemoryDetailCommand, ElementName=MemoryWorkspace}" CommandParameter="{Binding}">
                                            <TextBlock Text="{Binding PreviewText}" TextTrimming="CharacterEllipsis" />
                                        </Button>
                                    </DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Task outcomes" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="No task outcomes." Style="{StaticResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoTaskOutcomes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding Dashboard.RecentTaskOutcomes}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Indexed knowledge" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="No indexed documents." Style="{StaticResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoDocuments, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding Dashboard.RecentDocuments}">
                                    <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" /></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="12">
                    <Border Style="{StaticResource PersonalAiWorkspaceCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Add explicit memory" Style="{StaticResource PersonalAiSectionTitleTextStyle}" />
                            <TextBox PlaceholderText="What should AEDA remember?" MinHeight="76" AcceptsReturn="True"
                                     Text="{Binding NewMemoryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="Explicit memory content" />
                            <TextBox PlaceholderText="Why are you saving this?" Text="{Binding NewMemorySourceReason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="Memory source reason" />
                            <Button Content="Add memory" HorizontalAlignment="Left" Command="{Binding CreateExplicitMemoryCommand}" />
                            <TextBlock Text="{Binding SafeStatusMessage}" TextWrapping="Wrap" Style="{StaticResource PersonalAiMetadataTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PersonalAiWorkspaceCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Retrieval preview" Style="{StaticResource PersonalAiSectionTitleTextStyle}" />
                            <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox PlaceholderText="Preview query" Text="{Binding RetrievalQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Retrieval preview query" />
                                <Button Grid.Column="1" Content="Preview" Command="{Binding PreviewRetrievalCommand}" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding RetrievalPreview}">
                                <ItemsControl.ItemTemplate><DataTemplate>
                                    <StackPanel Margin="0,0,0,8"><TextBlock Text="{Binding SourceLabel}" FontWeight="SemiBold"/><TextBlock Text="{Binding PreviewText}" TextWrapping="Wrap" MaxLines="3"/></StackPanel>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PersonalAiWorkspaceCardStyle}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Selected source" Style="{StaticResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="{Binding SelectedMemory.Text}" TextWrapping="Wrap" MaxLines="4" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedMemory.Source.DisplayName}" Style="{StaticResource PersonalAiSecondaryTextStyle}" />
                            <TextBlock Text="{Binding SelectedMemory.Source.RelativePath}" TextTrimming="CharacterEllipsis" Style="{StaticResource PersonalAiMetadataTextStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
