<UserControl
    x:Class="PersonalAI.Desktop.WinUI.Controls.AedaDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <x:Double x:Key="AedaModuleCardHeight">190</x:Double>
        <DataTemplate x:Key="ModuleCardTemplate">
            <Button Command="{Binding OpenCommand}" IsEnabled="{Binding IsEnabled}"
                    Style="{StaticResource PersonalAiTileButtonStyle}"
                    Height="{StaticResource AedaModuleCardHeight}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    ToolTipService.ToolTip="{Binding ToolTipText}"
                    AutomationProperties.Name="{Binding AccessibleName}">
                <Border Background="{Binding Kind, Converter={StaticResource ModuleAccentFillConverter}}"
                        BorderBrush="{Binding Kind, Converter={StaticResource ModuleAccentBorderConverter}}"
                        BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="{StaticResource CardPadding}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Border Width="36" Height="36" CornerRadius="9" Background="#18FFFFFF">
                                <FontIcon Glyph="{Binding Glyph}" FontSize="18"
                                          Foreground="{Binding Kind, Converter={StaticResource ModuleAccentForegroundConverter}}" />
                            </Border>
                            <Border HorizontalAlignment="Right" Padding="8,3" CornerRadius="10"
                                    Background="#18FFFFFF">
                                <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding Kind, Converter={StaticResource ModuleAccentForegroundConverter}}" />
                            </Border>
                        </Grid>
                        <TextBlock Grid.Row="1" Text="{Binding DisplayName}" FontSize="17"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                   Foreground="{Binding Kind, Converter={StaticResource ModuleAccentForegroundConverter}}" />
                        <TextBlock Grid.Row="2" Text="{Binding ShortDescription}" TextWrapping="Wrap"
                                   MaxLines="3" LineHeight="19" Opacity="0.78"
                                   Foreground="{Binding Kind, Converter={StaticResource ModuleAccentForegroundConverter}}" />
                        <TextBlock Grid.Row="3" Text="{Binding CapabilityHintText}" FontSize="11"
                                   TextWrapping="Wrap" MaxLines="2" Opacity="0.68"
                                   Foreground="{Binding Kind, Converter={StaticResource ModuleAccentForegroundConverter}}" />
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
        <DataTemplate x:Key="ModuleGridTemplate">
            <ItemsRepeater ItemsSource="{Binding}"
                           ItemTemplate="{StaticResource ModuleCardTemplate}"
                           HorizontalAlignment="Stretch">
                <ItemsRepeater.Layout>
                    <UniformGridLayout Orientation="Horizontal"
                                       MaximumRowsOrColumns="2"
                                       MinItemWidth="360"
                                       MinItemHeight="190"
                                       MinColumnSpacing="14"
                                       MinRowSpacing="14"
                                       ItemsStretch="Fill" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </DataTemplate>
        <DataTemplate x:Key="DeferredCardTemplate">
            <Border Width="176" MinHeight="64" Margin="0,0,8,8" Padding="12,9"
                    CornerRadius="10" Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}" BorderThickness="1"
                    ToolTipService.ToolTip="{Binding DisplayName}">
                <StackPanel Spacing="3">
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                               TextWrapping="Wrap" MaxLines="2" />
                    <TextBlock Text="Coming later" FontSize="11"
                               Foreground="{ThemeResource PersonalAiMutedTextBrush}" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ActivityTemplate">
            <Border Padding="12,9" Margin="0,0,0,6" CornerRadius="9"
                    Background="{ThemeResource PersonalAiSubtleSurfaceBrush}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SafeSummary}" FontSize="11"
                                   Foreground="{ThemeResource PersonalAiSecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding UpdatedAt}" FontSize="11"
                               VerticalAlignment="Center" Foreground="{ThemeResource PersonalAiMutedTextBrush}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- System Mica: balanced, conventional Windows composition. -->
        <ScrollViewer Visibility="{Binding Settings.IsSystemMicaTheme, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Padding="28,24" Spacing="18">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Good to see you" FontSize="28" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ModuleDashboard.CurrentWorkspaceSummary}"
                                   Foreground="{ThemeResource PersonalAiSecondaryTextBrush}" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Padding="10,5" CornerRadius="10" Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"><TextBlock Text="Local" /></Border>
                        <Button Content="Open chat" Command="{Binding OpenChatCommand}" />
                    </StackPanel>
                </Grid>
                <ContentControl Content="{Binding ModuleDashboard.AvailableTiles}"
                                ContentTemplate="{StaticResource ModuleGridTemplate}" />
                <Border Padding="16" CornerRadius="10"
                        Background="{ThemeResource PersonalAiElevatedSurfaceBrush}" BorderBrush="{ThemeResource PersonalAiBorderBrush}" BorderThickness="1">
                    <StackPanel><TextBlock Text="Recent activity" Style="{StaticResource PersonalAiSectionTitleTextStyle}" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding ModuleDashboard.RecentTasks}" ItemTemplate="{StaticResource ActivityTemplate}" /></StackPanel>
                </Border>
                <StackPanel Spacing="8">
                    <TextBlock Text="Coming later" Style="{StaticResource PersonalAiSectionTitleTextStyle}" />
                    <ItemsControl ItemsSource="{Binding ModuleDashboard.DeferredTiles}"
                                  ItemTemplate="{StaticResource DeferredCardTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><ItemsWrapGrid Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Graphite: denser operational workspace. -->
        <ScrollViewer Visibility="{Binding Settings.IsGraphiteTheme, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Padding="28,20" Spacing="14">
                <Grid><StackPanel><TextBlock Text="AEDA Workspace" FontSize="25" FontWeight="SemiBold"/><TextBlock Text="Local modules and current operations" Foreground="{ThemeResource PersonalAiSecondaryTextBrush}"/></StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8"><TextBlock Text="{Binding TaskCenter.ActiveTaskCountText}"/><TextBlock Text="{Binding TaskCenter.WaitingApprovalCountText}"/></StackPanel></Grid>
                <ContentControl Content="{Binding ModuleDashboard.AvailableTiles}"
                                ContentTemplate="{StaticResource ModuleGridTemplate}" />
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Padding="16" CornerRadius="10" Background="{ThemeResource PersonalAiElevatedSurfaceBrush}" BorderBrush="{ThemeResource PersonalAiBorderBrush}" BorderThickness="1"><StackPanel><TextBlock Text="Activity stream" Style="{StaticResource PersonalAiSectionTitleTextStyle}" Margin="0,0,0,10"/><ItemsControl ItemsSource="{Binding ModuleDashboard.RecentTasks}" ItemTemplate="{StaticResource ActivityTemplate}"/></StackPanel></Border>
                    <Border Grid.Column="1" Padding="16" CornerRadius="10" Background="{ThemeResource PersonalAiElevatedSurfaceBrush}" BorderBrush="{ThemeResource PersonalAiStrongBorderBrush}" BorderThickness="1"><StackPanel><TextBlock Text="Workspace" FontWeight="SemiBold"/><TextBlock Text="{Binding ModuleDashboard.CurrentWorkspaceSummary}" TextWrapping="Wrap" Margin="0,6,0,14"/><Button Content="Open Task Center" Command="{Binding OpenTaskCenterCommand}"/></StackPanel></Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Mineral Stone: grouped two-column mineral cards. -->
        <ScrollViewer Visibility="{Binding Settings.IsMineralStoneTheme, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Padding="28,24" Spacing="18">
                <Grid><StackPanel><TextBlock Text="Your local workspace" FontSize="28" FontWeight="SemiBold"/><TextBlock Text="Focused tools, grounded in your selected projects" Foreground="{ThemeResource PersonalAiSecondaryTextBrush}"/></StackPanel><Image HorizontalAlignment="Right" Source="ms-appx:///Assets/AedaAppIcon.svg" Width="52" Height="52"/></Grid>
                <ContentControl Content="{Binding ModuleDashboard.AvailableTiles}"
                                ContentTemplate="{StaticResource ModuleGridTemplate}" />
                <Border Padding="16" CornerRadius="16" Background="{ThemeResource PersonalAiElevatedSurfaceBrush}" BorderBrush="{ThemeResource PersonalAiBorderBrush}" BorderThickness="1"><StackPanel><TextBlock Text="Recent activity" Style="{StaticResource PersonalAiSectionTitleTextStyle}" Margin="0,0,0,10"/><ItemsControl ItemsSource="{Binding ModuleDashboard.RecentTasks}" ItemTemplate="{StaticResource ActivityTemplate}"/></StackPanel></Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Sharp Almond: branded editorial asymmetric composition. -->
        <ScrollViewer Visibility="{Binding Settings.IsSharpAlmondTheme, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Padding="28,22" Spacing="12">
                <Border Padding="24,20" CornerRadius="16" Background="{ThemeResource AedaDashboardHeroBrush}" BorderBrush="{ThemeResource PersonalAiBorderBrush}" BorderThickness="1">
                    <Grid><StackPanel MaxWidth="580"><TextBlock Text="AEDA, ready when you are" FontSize="30" FontWeight="SemiBold"/><TextBlock Text="Local intelligence for code, memory, research, and deliberate work." FontSize="14" TextWrapping="Wrap" Margin="0,6,0,12" Foreground="{ThemeResource PersonalAiSecondaryTextBrush}"/><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Start a chat" Command="{Binding OpenChatCommand}"/><TextBlock Text="{Binding ModuleDashboard.CurrentWorkspaceSummary}" VerticalAlignment="Center" Foreground="{ThemeResource PersonalAiSecondaryTextBrush}"/></StackPanel></StackPanel><Image HorizontalAlignment="Right" Source="ms-appx:///Assets/AedaLogo.svg" Width="96" Height="96" Stretch="Uniform"/></Grid>
                </Border>
                <ContentControl Content="{Binding ModuleDashboard.AvailableTiles}"
                                ContentTemplate="{StaticResource ModuleGridTemplate}" />
                <Border Padding="16" CornerRadius="14" Background="{ThemeResource PersonalAiElevatedSurfaceBrush}" BorderBrush="{ThemeResource PersonalAiBorderBrush}" BorderThickness="1"><StackPanel><TextBlock Text="Recent work" Style="{StaticResource PersonalAiSectionTitleTextStyle}" Margin="0,0,0,10"/><ItemsControl ItemsSource="{Binding ModuleDashboard.RecentTasks}" ItemTemplate="{StaticResource ActivityTemplate}"/></StackPanel></Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
