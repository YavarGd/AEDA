<Window
    x:Class="PersonalAI.Desktop.WinUI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PersonalAI.Desktop.WinUI.Controls"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters"
    Title="PersonalAI">
    <Grid x:Name="Root"
          KeyDown="Root_KeyDown"
          MinWidth="1080"
          MinHeight="760"
          Background="{ThemeResource PersonalAiPageBackgroundBrush}">
        <Grid.Resources>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:ChatRoleSurfaceBrushConverter x:Key="ChatRoleSurfaceBrushConverter" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarColumnWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              MinWidth="240"
              MaxWidth="280"
              Margin="12,12,6,12"
              Padding="{Binding SidebarPadding}"
              CornerRadius="{StaticResource SidebarCornerRadius}"
              Background="{ThemeResource PersonalAiSidebarBackgroundBrush}"
              BorderBrush="{ThemeResource PersonalAiBorderBrush}"
              BorderThickness="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel MinWidth="0"
                            Spacing="2">
                    <TextBlock Text="PersonalAI"
                               Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="Local assistant"
                               Style="{ThemeResource PersonalAiMetadataTextStyle}"
                               TextWrapping="NoWrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource PersonalAiIconButtonStyle}"
                        Command="{Binding NewChatCommand}"
                        ToolTipService.ToolTip="New chat"
                        AutomationProperties.Name="New chat">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE710;"
                              FontSize="16" />
                </Button>
            </Grid>

            <TextBox Grid.Row="1"
                     Margin="0,0,0,16"
                     MinWidth="0"
                     CornerRadius="10"
                     PlaceholderText="Search conversations"
                     Text="{Binding ConversationSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="2"
                       Text="CONVERSATIONS"
                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                       CharacterSpacing="20"
                       Margin="4,0,0,10" />
            <ListView Grid.Row="3"
                      ItemsSource="{Binding Conversations}"
                      SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                      SelectionChanged="ConversationList_SelectionChanged"
                      Padding="0,0,0,8"
                      HorizontalContentAlignment="Stretch">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0,0,0,3" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="CornerRadius" Value="10" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="2"
                                    MinWidth="0"
                                    Padding="10,8">
                            <TextBlock Text="{Binding Title}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{Binding Title}" />
                            <TextBlock Text="{Binding Preview}"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                       TextWrapping="NoWrap"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding DataContext.ShowConversationMetadata, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock Grid.Row="3"
                       Text="No conversations yet"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                       Visibility="{Binding HasNoConversations, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,12,0,0">
                <Button Style="{StaticResource PersonalAiIconButtonStyle}"
                        Command="{Binding OpenDashboardCommand}"
                        ToolTipService.ToolTip="Module dashboard"
                        AutomationProperties.Name="Module dashboard">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE80F;"
                              FontSize="16" />
                </Button>
                <Button Style="{StaticResource PersonalAiIconButtonStyle}"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTipService.ToolTip="Settings"
                        AutomationProperties.Name="Settings">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE713;"
                              FontSize="16" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1"
              MinWidth="760"
              Padding="{StaticResource PagePadding}"
              Visibility="{Binding IsChatVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel MinWidth="0">
                    <TextBlock Text="{Binding CurrentConversationTitle}"
                               Style="{ThemeResource PersonalAiPageTitleTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}">
                        <TextBlock Text="Local"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            MaxWidth="220"
                            Visibility="{Binding HasConversationModelOverride, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTipService.ToolTip="{Binding ConversationModelOverrideLabel}">
                        <TextBlock Text="{Binding ConversationModelOverrideLabel}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            MaxWidth="260"
                            ToolTipService.ToolTip="{Binding RoutingStatusMessage}">
                        <TextBlock Text="{Binding RoutingStatusMessage}"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                </StackPanel>

                <ProgressRing Grid.Column="2"
                              Width="28"
                              Height="28"
                              IsActive="{Binding IsGenerating}" />
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,20,0,16"
                  MinWidth="0">
                <ListView x:Name="TimelineList"
                          ItemsSource="{Binding Messages}"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Top">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight"
                                    Value="0" />
                            <Setter Property="VerticalContentAlignment"
                                    Value="Top" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,8"
                                  MinWidth="0"
                                  VerticalAlignment="Top">
                                <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="{Binding BorderThickness}"
                                        CornerRadius="{Binding CornerRadius}"
                                        Background="{Binding Role, Converter={StaticResource ChatRoleSurfaceBrushConverter}}"
                                        Padding="{Binding Padding}"
                                        MaxWidth="{Binding MessageMaxWidth}"
                                        HorizontalAlignment="{Binding MessageHorizontalAlignment}">
                                    <StackPanel MinWidth="0">
                                        <TextBlock Text="{Binding MetadataText}"
                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                   Visibility="{Binding DataContext.ShowMessageMetadata, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="{Binding ContentTextWrapping}"
                                                   TextTrimming="{Binding ContentTextTrimming}"
                                                   MaxLines="{Binding ContentMaxLines}"
                                                   ToolTipService.ToolTip="{Binding Content}"
                                                   IsTextSelectionEnabled="True"
                                                   Visibility="{Binding UsesPlainTextPresenter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <controls:ChatMarkdownPresenter Content="{Binding RenderedContent}"
                                                                        Visibility="{Binding UsesMarkdownPresenter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6"
                                                    Margin="0,8,0,0">
                                            <Button Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                                    Command="{Binding DataContext.CopyMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    ToolTipService.ToolTip="Copy message"
                                                    AutomationProperties.Name="Copy message">
                                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                                          Glyph="&#xE8C8;"
                                                          FontSize="12" />
                                            </Button>
                                            <Button Content="Regenerate"
                                                    Command="{Binding DataContext.RegenerateMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanRegenerate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Retry"
                                                    Command="{Binding DataContext.RetryMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanRetry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Use automatic routing"
                                                    Command="{Binding DataContext.UseAutomaticRoutingCommand, ElementName=Root}"
                                                    Visibility="{Binding IsCapabilityBlocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Choose vision model"
                                                    Command="{Binding DataContext.ChooseVisionModelCommand, ElementName=Root}"
                                                    Visibility="{Binding IsCapabilityBlocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button x:Name="JumpToLatestButton"
                        Content="Jump to latest"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,16"
                        Padding="16,8"
                        CornerRadius="{StaticResource PillCornerRadius}"
                        Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                        BorderBrush="{ThemeResource PersonalAiStrongBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        Click="JumpToLatestButton_Click"
                        ToolTipService.ToolTip="Jump to latest"
                        AutomationProperties.Name="Jump to latest" />
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Visibility="{Binding IsTimelineEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="56"
                            Height="56"
                            CornerRadius="28"
                            Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            HorizontalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE8A5;"
                                  FontSize="22"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource PersonalAiMutedTextBrush}" />
                    </Border>
                    <TextBlock Text="Start a conversation"
                               Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Ask a question or attach context from the composer."
                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ComposerCornerRadius}"
                    Padding="16,14"
                    MinWidth="0">
                <Grid MinWidth="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0"
                              Margin="0,0,0,8"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding AttachedContexts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CardCornerRadius}"
                                        Padding="8"
                                        Margin="0,0,8,0"
                                        Width="184"
                                        Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                        ToolTipService.ToolTip="{Binding Preview}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE722;"
                                                  FontSize="16"
                                                  Margin="0,2,8,0"
                                                  Foreground="{ThemeResource PersonalAiSecondaryTextBrush}" />

                                        <StackPanel Grid.Column="1"
                                                    Spacing="1"
                                                    MinWidth="0">
                                            <TextBlock Text="{Binding DisplayTitle}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding SourceName}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Top"
                                                Command="{Binding DataContext.RemoveContextCommand, ElementName=Root}"
                                                CommandParameter="{Binding}"
                                                ToolTipService.ToolTip="Remove context"
                                                AutomationProperties.Name="Remove context">
                                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                                      Glyph="&#xE711;"
                                                      FontSize="12" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="1"
                        Margin="0,0,0,8"
                        Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                        BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="10"
                        Visibility="{Binding HasModuleSuggestion, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ModuleSuggestionMessage}"
                                   TextWrapping="Wrap"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                        <Button Grid.Column="1"
                                Content="Open in AEDA Code"
                                Command="{Binding OpenSuggestedModuleCommand}" />
                        <Button Grid.Column="2"
                                Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                Command="{Binding DismissModuleSuggestionCommand}"
                                ToolTipService.ToolTip="Dismiss suggestion"
                                AutomationProperties.Name="Dismiss module suggestion">
                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE711;"
                                      FontSize="12" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="2"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            HorizontalAlignment="Left"
                            Visibility="{Binding IsEditorConnected, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTipService.ToolTip="VS Code integration connected"
                            AutomationProperties.Name="VS Code integration connected">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE943;"
                                      FontSize="12" />
                            <TextBlock Text="VS Code"
                                       Style="{ThemeResource PersonalAiPillTextStyle}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding AttachedContextCount}"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <TextBlock Text="attached"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <Button Command="{Binding ClearAllContextsCommand}"
                                Content="Clear all"
                                Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3"
                      MinWidth="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource PersonalAiIconButtonStyle}"
                            Margin="0,0,12,0"
                            VerticalAlignment="Bottom"
                            ToolTipService.ToolTip="Add context"
                            AutomationProperties.Name="Add context">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE898;"
                                  FontSize="16" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Capture active app"
                                                Command="{Binding CaptureApplicationContextCommand}"
                                                AutomationProperties.Name="Capture active app">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE8B7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Attach clipboard text"
                                                Command="{Binding AttachClipboardContextCommand}"
                                                AutomationProperties.Name="Attach clipboard text">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE8C8;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Capture screenshot"
                                                Command="{Binding CaptureScreenshotContextCommand}"
                                                AutomationProperties.Name="Capture screenshot">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE722;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <TextBox x:Name="PromptTextBox"
                             Grid.Column="1"
                             AcceptsReturn="True"
                             MinWidth="360"
                             MinHeight="84"
                             MaxHeight="160"
                             CornerRadius="14"
                             BorderThickness="0"
                             Background="Transparent"
                             PlaceholderText="Ask anything"
                             Text="{Binding Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Style="{StaticResource PersonalAiPrimaryIconButtonStyle}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding SendMessageCommand}"
                            ToolTipService.ToolTip="Send"
                            AutomationProperties.Name="Send">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE74A;"
                                  FontSize="15" />
                    </Button>
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsMemoryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <StackPanel MinWidth="0"
                                DataContext="{Binding AedaMemory}">
                        <TextBlock Text="{Binding DisplayName}"
                                   Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding PrivacyStatusText}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Command="{Binding OpenDashboardCommand}"
                                Content="Dashboard" />
                        <Button Command="{Binding OpenChatCommand}"
                                Content="Chat" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0">
                <StackPanel x:Name="MemorySurface"
                            DataContext="{Binding AedaMemory}"
                            Spacing="20">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource PillCornerRadius}"
                                Padding="{StaticResource CompactControlPadding}">
                            <TextBlock Text="{Binding AvailabilityLabel}"
                                       Style="{ThemeResource PersonalAiPillTextStyle}" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding CapabilityBadges}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource PillCornerRadius}"
                                            Padding="{StaticResource CompactControlPadding}"
                                            Margin="0,0,8,0">
                                        <TextBlock Text="{Binding}"
                                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Overview"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="{Binding TotalMemoryCountText}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{Binding IndexedKnowledgeText}"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                            <TextBlock Text="{Binding RetrievalStatusText}"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                            <ItemsControl ItemsSource="{Binding CountSummaries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Add memory"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBox PlaceholderText="Explicit memory"
                                     Text="{Binding NewMemoryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     MinHeight="84"
                                     CornerRadius="10"
                                     AutomationProperties.Name="Explicit memory content" />
                            <TextBox PlaceholderText="Source reason"
                                     Text="{Binding NewMemorySourceReason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     CornerRadius="10"
                                     AutomationProperties.Name="Memory source reason" />
                            <Button Content="Add memory"
                                    Command="{Binding CreateExplicitMemoryCommand}"
                                    ToolTipService.ToolTip="Save only this explicit memory" />
                            <TextBlock Text="{Binding SafeStatusMessage}"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    </Border>

                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Search"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="360"
                                         PlaceholderText="Search memories"
                                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Search memories" />
                                <Button Content="Search"
                                        Command="{Binding SearchMemoriesCommand}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    Margin="0,0,0,8">
                                            <Button Content="Open"
                                                    Command="{Binding DataContext.OpenMemoryDetailCommand, ElementName=MemorySurface}"
                                                    CommandParameter="{Binding}" />
                                            <TextBlock Text="{Binding PreviewText}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Retrieval Preview"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="360"
                                         PlaceholderText="Preview query"
                                         Text="{Binding RetrievalQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Retrieval preview query" />
                                <Button Content="Preview"
                                        Command="{Binding PreviewRetrievalCommand}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding RetrievalPreview}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2"
                                                    Margin="0,0,0,8">
                                            <TextBlock Text="{Binding SourceLabel}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding PreviewText}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="3"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                    </Border>

                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Recent Memories"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No explicit memories yet."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoRecentMemories, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding Dashboard.RecentMemories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding PreviewText}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding SourceLabel}"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Button Content="Open"
                                                            Command="{Binding DataContext.OpenMemoryDetailCommand, ElementName=MemorySurface}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Archive"
                                                            Command="{Binding DataContext.ArchiveMemoryCommand, ElementName=MemorySurface}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Delete"
                                                            Command="{Binding DataContext.DeleteMemoryCommand, ElementName=MemorySurface}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Task Outcomes"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No task outcome memories."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoTaskOutcomes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding Dashboard.RecentTaskOutcomes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PreviewText}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                   Margin="0,0,0,8" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Spacing="8">
                            <TextBlock Text="Indexed Knowledge"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No indexed documents."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoDocuments, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding Dashboard.RecentDocuments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2"
                                                    Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Title}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding RelativePath}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                            <TextBlock Text="{Binding State}"
                                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                    </Border>

                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Source Detail"
                                   Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                        <TextBlock Text="{Binding SelectedMemory.Text}"
                                   TextWrapping="Wrap"
                                   MaxLines="5"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedMemory.Source.DisplayName}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                        <TextBlock Text="{Binding SelectedMemory.Source.RelativePath}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <TextBlock Text="{Binding SelectedMemory.Source.Excerpt}"
                                   TextWrapping="Wrap"
                                   MaxLines="4"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                    </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsDashboardVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <StackPanel MinWidth="0">
                        <TextBlock Text="Module Dashboard"
                                   Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding ModuleDashboard.CurrentWorkspaceSummary}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Command="{Binding OpenChatCommand}"
                            Content="Back to chat" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0">
                <StackPanel DataContext="{Binding ModuleDashboard}"
                            Spacing="20">
                    <GridView ItemsSource="{Binding ModuleTiles}"
                              SelectionMode="None"
                              IsItemClickEnabled="False"
                              HorizontalAlignment="Stretch">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,16,16" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                               MaximumRowsOrColumns="3" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Button Width="240"
                                        MinHeight="180"
                                        Style="{StaticResource PersonalAiTileButtonStyle}"
                                        Command="{Binding OpenCommand}"
                                        IsEnabled="{Binding IsEnabled}"
                                        ToolTipService.ToolTip="{Binding ToolTipText}"
                                        AutomationProperties.Name="{Binding AccessibleName}">
                                    <Border BorderBrush="{Binding DisplayName, Converter={StaticResource ModuleAccentBorderConverter}}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource CardCornerRadius}"
                                            Background="{Binding DisplayName, Converter={StaticResource ModuleAccentFillConverter}}"
                                            Padding="{StaticResource CardPadding}"
                                            Width="240"
                                            MinHeight="180">
                                        <StackPanel Spacing="8">
                                            <Grid>
                                                <Border Width="34"
                                                        Height="34"
                                                        CornerRadius="{StaticResource IconContainerCornerRadius}"
                                                        Background="#1AFFFFFF"
                                                        HorizontalAlignment="Left">
                                                    <FontIcon FontFamily="Segoe MDL2 Assets"
                                                              Glyph="{Binding Glyph}"
                                                              FontSize="17"
                                                              Foreground="{Binding DisplayName, Converter={StaticResource ModuleAccentForegroundConverter}}" />
                                                </Border>
                                                <Border HorizontalAlignment="Right"
                                                        Background="#1AFFFFFF"
                                                        BorderThickness="0"
                                                        CornerRadius="{StaticResource PillCornerRadius}"
                                                        Padding="{StaticResource CompactControlPadding}">
                                                    <TextBlock Text="{Binding StatusLabel}"
                                                               Style="{ThemeResource PersonalAiPillTextStyle}"
                                                               Foreground="{Binding DisplayName, Converter={StaticResource ModuleAccentForegroundConverter}}" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ShortDescription}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="3"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                            <TextBlock Text="{Binding CapabilityHintText}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            <TextBlock Text="{Binding SafeUnavailableReason}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                       Visibility="{Binding HasUnavailableReason, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Active Tasks"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No active tasks"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoActiveTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding ActiveTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding SafeSummary}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                <TextBlock Text="{Binding UpdatedAt}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Recent Tasks"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No recent tasks"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoRecentTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding RecentTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding SafeSummary}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                <TextBlock Text="{Binding UpdatedAt}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsCodeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <StackPanel MinWidth="0"
                                DataContext="{Binding AedaCode}">
                        <TextBlock Text="{Binding DisplayName}"
                                   Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding WorkspaceSummary}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Command="{Binding OpenDashboardCommand}"
                                Content="Dashboard" />
                        <Button Command="{Binding OpenChatCommand}"
                                Content="Chat" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0">
                <StackPanel DataContext="{Binding AedaCode}"
                            Spacing="20">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource PillCornerRadius}"
                                Padding="{StaticResource CompactControlPadding}">
                            <TextBlock Text="{Binding AvailabilityLabel}"
                                       Style="{ThemeResource PersonalAiPillTextStyle}" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding CapabilityBadges}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource PillCornerRadius}"
                                            Padding="{StaticResource CompactControlPadding}"
                                            Margin="0,0,8,0">
                                        <TextBlock Text="{Binding}"
                                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Recent Sessions"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No recent AEDA Code sessions."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoRecentSessions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding RecentSessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding SafeSummary}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding WorkspaceDisplayName}"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Safe Actions"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <Button Content="Start code session"
                                    IsEnabled="False"
                                    ToolTipService.ToolTip="Session start is deferred to the guided Code workflow." />
                            <Button Content="View proposals"
                                    IsEnabled="False"
                                    ToolTipService.ToolTip="Proposal browsing is read-model only in this milestone." />
                            <Button Content="View validation runs"
                                    IsEnabled="False"
                                    ToolTipService.ToolTip="Validation is not started from this page." />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Recent Proposals"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No proposal summaries loaded."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoProposalSummaries, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding ProposalSummaries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding Status}"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Validation Runs"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No validation summaries loaded."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoValidationSummaries, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding ValidationSummaries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding TemplateId}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding Status}"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Apply Results and Timeline"
                                   Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                        <TextBlock Text="No apply results loaded."
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   Visibility="{Binding HasNoApplySummaries, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding ApplySummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No task timeline loaded."
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   Visibility="{Binding HasNoTimelineSummaries, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding TimelineSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Summary}"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <TextBlock Text="Settings"
                               Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                    <Button HorizontalAlignment="Right"
                            Command="{Binding CloseSettingsCommand}"
                            Content="Done" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0">
                <StackPanel DataContext="{Binding Settings}"
                            MaxWidth="800"
                            Spacing="12"
                            HorizontalAlignment="Left">
                    <Expander Header="General"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Launch destination"
                                      ItemsSource="{Binding LaunchDestinationOptions}"
                                      SelectedItem="{Binding LaunchDestination, Mode=TwoWay}" />
                            <CheckBox Content="Preserve composer draft between hide/show"
                                      IsChecked="{Binding PreserveComposerDraftBetweenHideShow, Mode=TwoWay}" />
                            <CheckBox Content="Confirm before clearing all attached context"
                                      IsChecked="{Binding ConfirmBeforeClearingAllContext, Mode=TwoWay}" />
                            <TextBlock Text="{Binding SettingsPath}"
                                       TextWrapping="Wrap"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Workspaces"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="True">
                        <StackPanel x:Name="WorkspaceManagementPanel"
                                    DataContext="{Binding Workspaces}"
                                    Spacing="12">
                            <TextBlock Text="Workspaces"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="Only folders you explicitly register here are available to workspace tools. Current tools are read-only and ask for permission before reading."
                                       TextWrapping="Wrap"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Add workspace"
                                        Command="{Binding PickWorkspaceFolderCommand}"
                                        AutomationProperties.Name="Add workspace folder" />
                                <Button Content="Revalidate all"
                                        Command="{Binding RevalidateAllCommand}" />
                                <Button Content="Refresh list"
                                        Command="{Binding RefreshCommand}" />
                                <ProgressRing Width="20"
                                              Height="20"
                                              IsActive="{Binding IsBusy}" />
                                <TextBlock Text="{Binding BusyMessage}"
                                           VerticalAlignment="Center"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                <TextBlock Text="{Binding StatusMessage}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                    BorderThickness="1"
                                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                    CornerRadius="{StaticResource CardCornerRadius}"
                                    Padding="{StaticResource CardPadding}"
                                    Visibility="{Binding HasPendingWorkspace, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Review workspace"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBox Header="Selected folder"
                                             Text="{Binding PendingFolderPath}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap" />
                                    <TextBox Header="Display name"
                                             Text="{Binding PendingDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Workspace tools may request permission to read files in this folder. Current workspace tools are read-only and cannot change files. Symlinks and junctions are rejected."
                                               TextWrapping="Wrap"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="Add workspace"
                                                Command="{Binding AddPendingWorkspaceCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding CancelPendingWorkspaceCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="No workspaces registered."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoWorkspaces, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Workspaces}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                        <TextBlock Text="{Binding ShortRootPath}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                                   ToolTipService.ToolTip="{Binding RootPath}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource PillCornerRadius}"
                                                            Padding="{StaticResource CompactControlPadding}"
                                                            Margin="12,0,0,0">
                                                        <TextBlock Text="{Binding ReadOnlyBadge}"
                                                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                                                    </Border>
                                                </Grid>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <TextBlock Text="{Binding StatusSymbol}" />
                                                    <TextBlock Text="{Binding Status}" />
                                                    <TextBlock Text="{Binding StatusDetail}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                </StackPanel>
                                                <Expander Header="Details"
                                                          IsExpanded="False">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{Binding WorkspaceId}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Source}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                        <TextBlock Text="{Binding AddedAt}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                        <TextBlock Text="{Binding LastValidated}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                    </StackPanel>
                                                </Expander>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Button Content="Rename"
                                                            Command="{Binding DataContext.RenameWorkspaceCommand, ElementName=WorkspaceManagementPanel}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Revalidate"
                                                            Command="{Binding DataContext.RevalidateWorkspaceCommand, ElementName=WorkspaceManagementPanel}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Remove"
                                                            Command="{Binding DataContext.RemoveWorkspaceCommand, ElementName=WorkspaceManagementPanel}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Appearance"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Theme"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding Theme, Mode=TwoWay}" />
                            <CheckBox Content="Compact sidebar"
                                      IsChecked="{Binding CompactSidebar, Mode=TwoWay}" />
                            <CheckBox Content="Show message metadata"
                                      IsChecked="{Binding ShowMessageMetadata, Mode=TwoWay}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Models"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Refresh models"
                                        Command="{Binding RefreshModelsCommand}" />
                                <Button Content="Reset assignments"
                                        Command="{Binding ResetModelAssignmentsCommand}" />
                                <TextBlock Text="{Binding ModelRefreshStatus}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            </StackPanel>
                            <ComboBox Header="General"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding GeneralModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Coding"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding CodingModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Vision"
                                      ItemsSource="{Binding VisionModels}"
                                      SelectedItem="{Binding VisionModel, Mode=TwoWay}"
                                      IsEditable="False" />
                            <ComboBox Header="Fast"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding FastModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Reasoning"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding ReasoningModel, Mode=TwoWay}"
                                      IsEditable="True" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Integrations"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12">
                                <CheckBox Content="Ctrl"
                                          IsChecked="{Binding HotkeyControl, Mode=TwoWay}" />
                                <CheckBox Content="Alt"
                                          IsChecked="{Binding HotkeyAlt, Mode=TwoWay}" />
                                <CheckBox Content="Shift"
                                          IsChecked="{Binding HotkeyShift, Mode=TwoWay}" />
                                <CheckBox Content="Win"
                                          IsChecked="{Binding HotkeyWindows, Mode=TwoWay}" />
                            </StackPanel>
                            <TextBox Header="Key"
                                     Text="{Binding HotkeyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Apply hotkey"
                                        Command="{Binding ApplyHotkeyCommand}" />
                                <Button Content="Reset hotkey"
                                        Command="{Binding ResetHotkeyCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Window and startup"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Close behavior"
                                      ItemsSource="{Binding CloseBehaviorOptions}"
                                      SelectedItem="{Binding CloseBehavior, Mode=TwoWay}" />
                            <CheckBox Content="Start minimized to tray"
                                      IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}" />
                            <CheckBox Content="Remember window position"
                                      IsChecked="{Binding RememberWindowPosition, Mode=TwoWay}" />
                            <CheckBox Content="Launch at Windows sign-in"
                                      IsChecked="{Binding LaunchAtSignIn, Mode=TwoWay}" />
                            <Button Content="Apply startup setting"
                                    Command="{Binding ToggleStartupCommand}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Privacy"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <NumberBox Header="Max total text context characters"
                                       Value="{Binding MaxTotalTextContextCharacters, Mode=TwoWay}" />
                            <NumberBox Header="Max clipboard attachment characters"
                                       Value="{Binding MaxIndividualClipboardCharacters, Mode=TwoWay}" />
                            <NumberBox Header="Max attached context items"
                                       Value="{Binding MaxAttachedContextItems, Mode=TwoWay}" />
                            <NumberBox Header="Screenshot max payload bytes"
                                       Value="{Binding ScreenshotMaxPayloadBytes, Mode=TwoWay}" />
                            <NumberBox Header="Screenshot thumbnail max edge"
                                       Value="{Binding ScreenshotThumbnailMaxEdge, Mode=TwoWay}" />
                            <CheckBox Content="Clear attachments after successful send"
                                      IsChecked="{Binding ClearAttachmentsAfterSuccessfulSend, Mode=TwoWay}" />
                            <CheckBox Content="Include executable path in provider metadata"
                                      IsChecked="{Binding IncludeExecutablePathInProviderMetadata, Mode=TwoWay}" />
                            <CheckBox Content="Include window title in provider context"
                                      IsChecked="{Binding IncludeWindowTitleInProviderContext, Mode=TwoWay}" />
                            <TextBox Header="Excluded applications (one process name per line)"
                                     AcceptsReturn="True"
                                     MinHeight="120"
                                     Text="{Binding ExcludedApplicationsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Developer diagnostics"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <TextBox Header="Additional vision model patterns"
                                     AcceptsReturn="True"
                                     MinHeight="96"
                                     Text="{Binding VisionPatternsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding SchemaVersionDisplay}"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Open settings folder"
                                        Command="{Binding OpenSettingsFolderCommand}" />
                                <Button Content="Reset window position"
                                        Command="{Binding ResetWindowPositionCommand}" />
                            </StackPanel>
                            <Button Content="Reset all settings"
                                    Command="{Binding ResetAllCommand}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Developer"
                              IsExpanded="False"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              DataContext="{Binding DataContext, ElementName=Root}"
                              Visibility="{Binding IsDeveloperDiagnosticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Developer workspace tools"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            <Button Content="Run UTC reference tool"
                                    HorizontalAlignment="Left"
                                    Command="{Binding RunReferenceToolCommand}" />
                            <TextBox PlaceholderText="Registered workspace ID from Settings"
                                     Text="{Binding DeveloperWorkspaceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="220"
                                         PlaceholderText="Relative path"
                                         Text="{Binding DeveloperToolPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="List"
                                        Command="{Binding RunDeveloperListDirectoryCommand}" />
                                <Button Content="Read"
                                        Command="{Binding RunDeveloperReadFileCommand}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="360"
                                         PlaceholderText="Literal search query"
                                         Text="{Binding DeveloperSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="Search"
                                        Command="{Binding RunDeveloperSearchWorkspaceCommand}" />
                            </StackPanel>
                            <TextBlock Text="{Binding DeveloperToolResult}"
                                       TextWrapping="Wrap"
                                       MaxHeight="120"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
