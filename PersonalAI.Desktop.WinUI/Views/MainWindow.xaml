<Window
    x:Class="PersonalAI.Desktop.WinUI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters"
    Title="PersonalAI">
    <Grid x:Name="Root"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarColumnWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Padding="{Binding SidebarPadding}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Command="{Binding NewChatCommand}"
                    Content="New chat"
                    HorizontalAlignment="Stretch" />
            <TextBox Grid.Row="1"
                     Margin="0,12,0,12"
                     PlaceholderText="Search conversations"
                     Text="{Binding ConversationSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ListView Grid.Row="2"
                      ItemsSource="{Binding Conversations}"
                      SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                      SelectionChanged="ConversationList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Title}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{Binding Title}" />
                            <TextBlock Text="{Binding Preview}"
                                       Opacity="0.7"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding DataContext.ShowConversationMetadata, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock Grid.Row="2"
                       Text="No conversations yet"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.7"
                       Visibility="{Binding HasNoConversations, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button Grid.Row="3"
                    Content="Settings"
                    Command="{Binding OpenSettingsCommand}"
                    HorizontalAlignment="Stretch" />
        </Grid>

        <Grid Grid.Column="1"
              Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding CurrentConversationTitle}"
                               Style="{ThemeResource TitleTextBlockStyle}" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Opacity="0.7" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding RoutingStatusMessage}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           MaxWidth="320"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis"
                           ToolTipService.ToolTip="{Binding RoutingStatusMessage}" />

                <ProgressRing Grid.Column="2"
                              Width="28"
                              Height="28"
                              Margin="16,24,0,0"
                              IsActive="{Binding IsGenerating}" />

                <Button Grid.Column="3"
                        Margin="12,20,0,0"
                        VerticalAlignment="Center"
                        Command="{Binding RunReferenceToolCommand}"
                        Content="Dev UTC"
                        Visibility="{Binding IsDeveloperDiagnosticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,24">
                <ListView x:Name="TimelineList"
                          ItemsSource="{Binding Messages}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,8">
                                <StackPanel MaxWidth="820">
                                    <TextBlock Text="{Binding RoleLabel}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.7"
                                               Visibility="{Binding DataContext.ShowMessageMetadata, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <TextBlock Text="{Binding Content}"
                                               TextWrapping="Wrap"
                                               IsTextSelectionEnabled="True" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock Text="Start a new chat or choose a conversation"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           Visibility="{Binding IsTimelineEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Spacing="8"
                            Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Command="{Binding CaptureApplicationContextCommand}"
                                    Content="Capture app" />
                            <Button Command="{Binding AttachClipboardContextCommand}"
                                    Content="Clipboard" />
                            <Button Command="{Binding CaptureScreenshotContextCommand}"
                                    Content="Screenshot" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding AttachedContextCount}"
                                       Opacity="0.7" />
                            <TextBlock Text="attached"
                                       Opacity="0.7" />
                            <Button Command="{Binding ClearAllContextsCommand}"
                                    Content="Clear all"
                                    Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding EditorConnectionStatus}"
                               Opacity="0.7" />
                    <TextBlock Text="{Binding ContextStatusMessage}"
                               Opacity="0.7" />

                    <StackPanel Spacing="6"
                                Visibility="{Binding TaskTimeline.HasEvents, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding TaskTimeline.CurrentState}"
                                   Opacity="0.75"
                                   TextTrimming="CharacterEllipsis" />
                        <ListView ItemsSource="{Binding TaskTimeline.Events}"
                                  MaxHeight="104"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Timestamp}"
                                                   Opacity="0.65" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Kind}"
                                                   Opacity="0.75" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Summary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTipService.ToolTip="{Binding Detail}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel Spacing="8"
                                Visibility="{Binding IsDeveloperDiagnosticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Developer workspace tools"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.75" />
                        <TextBox PlaceholderText="Workspace root to explicitly register"
                                 Text="{Binding DeveloperWorkspaceRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="Register workspace"
                                    Command="{Binding RegisterDeveloperWorkspaceCommand}" />
                            <TextBox Width="220"
                                     PlaceholderText="Relative path"
                                     Text="{Binding DeveloperToolPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="List"
                                    Command="{Binding RunDeveloperListDirectoryCommand}" />
                            <Button Content="Read"
                                    Command="{Binding RunDeveloperReadFileCommand}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBox Width="360"
                                     PlaceholderText="Literal search query"
                                     Text="{Binding DeveloperSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="Search"
                                    Command="{Binding RunDeveloperSearchWorkspaceCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding DeveloperToolResult}"
                                   TextWrapping="Wrap"
                                   MaxHeight="120"
                                   Opacity="0.75" />
                    </StackPanel>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding AttachedContexts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,0,8,0"
                                            MaxWidth="320"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            ToolTipService.ToolTip="{Binding Preview}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Spacing="2">
                                                <Image Source="{Binding ThumbnailDataUri}"
                                                       MaxWidth="180"
                                                       MaxHeight="100"
                                                       Stretch="Uniform"
                                                       HorizontalAlignment="Left" />
                                                <TextBlock Text="{Binding Type}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Opacity="0.7" />
                                                <TextBlock Text="{Binding DisplayTitle}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding SourceName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Opacity="0.75" />
                                                <TextBlock Text="{Binding Preview}"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2"
                                                           Opacity="0.75" />
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Top"
                                                    Command="{Binding DataContext.RemoveContextCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Content="Remove" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="PromptTextBox"
                             AcceptsReturn="True"
                             MinHeight="88"
                             PlaceholderText="Ask PersonalAI"
                             Text="{Binding Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             KeyDown="PromptTextBox_KeyDown" />
                    <Button Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding SendMessageCommand}"
                            Content="Send" />
                    <Button Grid.Column="2"
                            Margin="8,0,0,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding CancelGenerationCommand}"
                            Content="Stop"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Column="1"
              Padding="24"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <TextBlock Text="Settings"
                           Style="{ThemeResource TitleTextBlockStyle}" />
                <Button HorizontalAlignment="Right"
                        Command="{Binding CloseSettingsCommand}"
                        Content="Done" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0">
                <StackPanel DataContext="{Binding Settings}"
                            MaxWidth="760"
                            Spacing="20"
                            HorizontalAlignment="Left">
                    <Expander Header="General"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Launch destination"
                                      ItemsSource="{Binding LaunchDestinationOptions}"
                                      SelectedItem="{Binding LaunchDestination, Mode=TwoWay}" />
                            <CheckBox Content="Preserve composer draft between hide/show"
                                      IsChecked="{Binding PreserveComposerDraftBetweenHideShow, Mode=TwoWay}" />
                            <CheckBox Content="Confirm before clearing all attached context"
                                      IsChecked="{Binding ConfirmBeforeClearingAllContext, Mode=TwoWay}" />
                            <TextBlock Text="{Binding SettingsPath}"
                                       TextWrapping="Wrap"
                                       Opacity="0.7" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Appearance"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Theme"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding Theme, Mode=TwoWay}" />
                            <CheckBox Content="Compact sidebar"
                                      IsChecked="{Binding CompactSidebar, Mode=TwoWay}" />
                            <CheckBox Content="Show message metadata"
                                      IsChecked="{Binding ShowMessageMetadata, Mode=TwoWay}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Advanced model routing"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Refresh models"
                                        Command="{Binding RefreshModelsCommand}" />
                                <Button Content="Reset assignments"
                                        Command="{Binding ResetModelAssignmentsCommand}" />
                                <TextBlock Text="{Binding ModelRefreshStatus}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Opacity="0.7" />
                            </StackPanel>
                            <ComboBox Header="General"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding GeneralModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Coding"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding CodingModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Vision"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding VisionModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Fast"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding FastModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Reasoning"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding ReasoningModel, Mode=TwoWay}"
                                      IsEditable="True" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Hotkey"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12">
                                <CheckBox Content="Ctrl"
                                          IsChecked="{Binding HotkeyControl, Mode=TwoWay}" />
                                <CheckBox Content="Alt"
                                          IsChecked="{Binding HotkeyAlt, Mode=TwoWay}" />
                                <CheckBox Content="Shift"
                                          IsChecked="{Binding HotkeyShift, Mode=TwoWay}" />
                                <CheckBox Content="Win"
                                          IsChecked="{Binding HotkeyWindows, Mode=TwoWay}" />
                            </StackPanel>
                            <TextBox Header="Key"
                                     Text="{Binding HotkeyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Apply hotkey"
                                        Command="{Binding ApplyHotkeyCommand}" />
                                <Button Content="Reset hotkey"
                                        Command="{Binding ResetHotkeyCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Window and startup"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Close behavior"
                                      ItemsSource="{Binding CloseBehaviorOptions}"
                                      SelectedItem="{Binding CloseBehavior, Mode=TwoWay}" />
                            <CheckBox Content="Start minimized to tray"
                                      IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}" />
                            <CheckBox Content="Remember window position"
                                      IsChecked="{Binding RememberWindowPosition, Mode=TwoWay}" />
                            <CheckBox Content="Launch at Windows sign-in"
                                      IsChecked="{Binding LaunchAtSignIn, Mode=TwoWay}" />
                            <Button Content="Apply startup setting"
                                    Command="{Binding ToggleStartupCommand}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Context and privacy"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <NumberBox Header="Max total text context characters"
                                       Value="{Binding MaxTotalTextContextCharacters, Mode=TwoWay}" />
                            <NumberBox Header="Max clipboard attachment characters"
                                       Value="{Binding MaxIndividualClipboardCharacters, Mode=TwoWay}" />
                            <NumberBox Header="Max attached context items"
                                       Value="{Binding MaxAttachedContextItems, Mode=TwoWay}" />
                            <NumberBox Header="Screenshot max payload bytes"
                                       Value="{Binding ScreenshotMaxPayloadBytes, Mode=TwoWay}" />
                            <NumberBox Header="Screenshot thumbnail max edge"
                                       Value="{Binding ScreenshotThumbnailMaxEdge, Mode=TwoWay}" />
                            <CheckBox Content="Clear attachments after successful send"
                                      IsChecked="{Binding ClearAttachmentsAfterSuccessfulSend, Mode=TwoWay}" />
                            <CheckBox Content="Include executable path in provider metadata"
                                      IsChecked="{Binding IncludeExecutablePathInProviderMetadata, Mode=TwoWay}" />
                            <CheckBox Content="Include window title in provider context"
                                      IsChecked="{Binding IncludeWindowTitleInProviderContext, Mode=TwoWay}" />
                            <TextBox Header="Excluded applications (one process name per line)"
                                     AcceptsReturn="True"
                                     MinHeight="120"
                                     Text="{Binding ExcludedApplicationsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Vision and diagnostics"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <TextBox Header="Additional vision model patterns"
                                     AcceptsReturn="True"
                                     MinHeight="96"
                                     Text="{Binding VisionPatternsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding SchemaVersionDisplay}"
                                       Opacity="0.7" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Open settings folder"
                                        Command="{Binding OpenSettingsFolderCommand}" />
                                <Button Content="Reset window position"
                                        Command="{Binding ResetWindowPositionCommand}" />
                            </StackPanel>
                            <Button Content="Reset all settings"
                                    Command="{Binding ResetAllCommand}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
