<Window
    x:Class="PersonalAI.Desktop.WinUI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PersonalAI.Desktop.WinUI.Controls"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters"
    Title="AEDA">
    <Grid x:Name="Root"
          KeyDown="Root_KeyDown"
          MinWidth="1080"
          MinHeight="760"
          Background="{ThemeResource PersonalAiPageBackgroundBrush}">
        <Grid.Resources>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:ChatRoleSurfaceBrushConverter x:Key="ChatRoleSurfaceBrushConverter" />
            <converters:ThemePreviewBrushConverter x:Key="ThemePreviewBrushConverter" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarDragRegion"
              Grid.Row="0"
              Padding="16,0,140,0"
              Background="{ThemeResource PersonalAiSidebarBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/AedaAppIcon.svg" Width="28" Height="28"
                       Stretch="Uniform" AutomationProperties.Name="AEDA logo" />
                <TextBlock Text="AEDA" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{ThemeResource AedaNavigationForegroundBrush}" />
                <TextBlock Text="Local intelligence workspace" FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource AedaNavigationSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <Grid x:Name="ShellGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="8,8,4,8"
              Padding="6"
              CornerRadius="14"
              Background="{ThemeResource PersonalAiSidebarBackgroundBrush}"
              BorderBrush="{ThemeResource PersonalAiBorderBrush}"
              BorderThickness="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Source="ms-appx:///Assets/AedaAppIcon.svg"
                   Width="46" Height="46" Margin="0,4,0,18" Stretch="Uniform"
                   AutomationProperties.Name="AEDA" />
            <StackPanel Grid.Row="1" Spacing="8">
                <RadioButton Style="{StaticResource AedaNavigationButtonStyle}"
                             GroupName="AedaPrimaryNavigation"
                             IsChecked="{Binding IsDashboardVisible, Mode=OneWay}"
                             Command="{Binding OpenDashboardCommand}" ToolTipService.ToolTip="Dashboard"
                             AutomationProperties.Name="Dashboard">
                    <FontIcon Glyph="&#xE80F;" />
                </RadioButton>
                <RadioButton Style="{StaticResource AedaNavigationButtonStyle}"
                             GroupName="AedaPrimaryNavigation"
                             IsChecked="{Binding IsChatVisible, Mode=OneWay}"
                             Command="{Binding OpenChatCommand}" ToolTipService.ToolTip="Chat"
                             AutomationProperties.Name="Chat">
                    <FontIcon Glyph="&#xE8BD;" />
                </RadioButton>
                <RadioButton Style="{StaticResource AedaNavigationButtonStyle}"
                             GroupName="AedaPrimaryNavigation"
                             IsChecked="{Binding IsTaskCenterVisible, Mode=OneWay}"
                             Command="{Binding OpenTaskCenterCommand}" ToolTipService.ToolTip="Task Center"
                             AutomationProperties.Name="Task Center">
                    <FontIcon Glyph="&#xE9D9;" />
                </RadioButton>
            </StackPanel>
            <RadioButton Grid.Row="2" Style="{StaticResource AedaNavigationButtonStyle}"
                         GroupName="AedaPrimaryNavigation"
                         IsChecked="{Binding IsSettingsVisible, Mode=OneWay}"
                         Command="{Binding OpenSettingsCommand}" ToolTipService.ToolTip="Settings"
                         AutomationProperties.Name="Settings">
                <FontIcon Glyph="&#xE713;" />
            </RadioButton>
        </Grid>

        <Grid Grid.Column="1"
              MinWidth="760"
              Padding="{StaticResource PagePadding}"
              Visibility="{Binding IsChatVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="3" Grid.Column="0" Margin="0,0,18,0"
                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <TextBlock Text="Conversations" Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                                   VerticalAlignment="Center" />
                        <Button HorizontalAlignment="Right" Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                Command="{Binding NewChatCommand}" ToolTipService.ToolTip="New chat"
                                AutomationProperties.Name="New chat"><FontIcon Glyph="&#xE710;" /></Button>
                    </Grid>
                    <TextBox Grid.Row="1" PlaceholderText="Search" MinWidth="0"
                             Text="{Binding ConversationSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ListView Grid.Row="2" ItemsSource="{Binding Conversations}"
                              SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                              SelectionChanged="ConversationList_SelectionChanged"
                              HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8,7" Spacing="2" MinWidth="0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Preview}" FontSize="11"
                                               Foreground="{ThemeResource PersonalAiSecondaryTextBrush}"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.Row="0" Grid.Column="1"
                  ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel MinWidth="0">
                    <TextBlock Text="{Binding CurrentConversationTitle}"
                               Style="{ThemeResource PersonalAiPageTitleTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}">
                        <TextBlock Text="Local"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            MaxWidth="220"
                            Visibility="{Binding HasConversationModelOverride, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTipService.ToolTip="{Binding ConversationModelOverrideLabel}">
                        <TextBlock Text="{Binding ConversationModelOverrideLabel}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            MaxWidth="260"
                            ToolTipService.ToolTip="{Binding RoutingStatusMessage}">
                        <TextBlock Text="{Binding RoutingStatusMessage}"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <ProgressRing Width="28" Height="28" IsActive="{Binding IsGenerating}" />
                    <Button Content="Stop" Command="{Binding CancelGenerationCommand}"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}"
                            AutomationProperties.Name="Stop generation" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="1"
                  Margin="0,20,0,16"
                  MinWidth="0">
                <ListView x:Name="TimelineList"
                          ItemsSource="{Binding Messages}"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Top">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight"
                                    Value="0" />
                            <Setter Property="VerticalContentAlignment"
                                    Value="Top" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,8"
                                  MinWidth="0"
                                  VerticalAlignment="Top">
                                <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="{Binding BorderThickness}"
                                        CornerRadius="{Binding CornerRadius}"
                                        Background="{Binding Role, Converter={StaticResource ChatRoleSurfaceBrushConverter}}"
                                        Padding="{Binding Padding}"
                                        MaxWidth="{Binding MessageMaxWidth}"
                                        HorizontalAlignment="{Binding MessageHorizontalAlignment}">
                                    <StackPanel MinWidth="0">
                                        <TextBlock Text="{Binding MetadataText}"
                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                   Visibility="{Binding DataContext.ShowMessageMetadata, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="{Binding ContentTextWrapping}"
                                                   TextTrimming="{Binding ContentTextTrimming}"
                                                   MaxLines="{Binding ContentMaxLines}"
                                                   ToolTipService.ToolTip="{Binding Content}"
                                                   IsTextSelectionEnabled="True"
                                                   Visibility="{Binding UsesPlainTextPresenter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <controls:ChatMarkdownPresenter Content="{Binding RenderedContent}"
                                                                        Visibility="{Binding UsesMarkdownPresenter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6"
                                                    Margin="0,8,0,0">
                                            <Button Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                                    Command="{Binding DataContext.CopyMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    ToolTipService.ToolTip="Copy message"
                                                    AutomationProperties.Name="Copy message">
                                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                                          Glyph="&#xE8C8;"
                                                          FontSize="12" />
                                            </Button>
                                            <Button Content="Regenerate"
                                                    Command="{Binding DataContext.RegenerateMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanRegenerate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Retry"
                                                    Command="{Binding DataContext.RetryMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanRetry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Use automatic routing"
                                                    Command="{Binding DataContext.UseAutomaticRoutingCommand, ElementName=Root}"
                                                    Visibility="{Binding IsCapabilityBlocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Choose vision model"
                                                    Command="{Binding DataContext.ChooseVisionModelCommand, ElementName=Root}"
                                                    Visibility="{Binding IsCapabilityBlocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button x:Name="JumpToLatestButton"
                        Content="Jump to latest"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,16"
                        Padding="16,8"
                        CornerRadius="{StaticResource PillCornerRadius}"
                        Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                        BorderBrush="{ThemeResource PersonalAiStrongBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        Click="JumpToLatestButton_Click"
                        ToolTipService.ToolTip="Jump to latest"
                        AutomationProperties.Name="Jump to latest" />
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Visibility="{Binding IsTimelineEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="56"
                            Height="56"
                            CornerRadius="28"
                            Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            HorizontalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE8A5;"
                                  FontSize="22"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource PersonalAiMutedTextBrush}" />
                    </Border>
                    <TextBlock Text="Start a conversation"
                               Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Ask a question or attach context from the composer."
                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Grid.Column="1"
                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ComposerCornerRadius}"
                    Padding="16,14"
                    MinWidth="0">
                <Grid MinWidth="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0"
                              Margin="0,0,0,8"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding AttachedContexts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CardCornerRadius}"
                                        Padding="8"
                                        Margin="0,0,8,0"
                                        Width="184"
                                        Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                        ToolTipService.ToolTip="{Binding Preview}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE722;"
                                                  FontSize="16"
                                                  Margin="0,2,8,0"
                                                  Foreground="{ThemeResource PersonalAiSecondaryTextBrush}" />

                                        <StackPanel Grid.Column="1"
                                                    Spacing="1"
                                                    MinWidth="0">
                                            <TextBlock Text="{Binding DisplayTitle}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding SourceName}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Top"
                                                Command="{Binding DataContext.RemoveContextCommand, ElementName=Root}"
                                                CommandParameter="{Binding}"
                                                ToolTipService.ToolTip="Remove context"
                                                AutomationProperties.Name="Remove context">
                                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                                      Glyph="&#xE711;"
                                                      FontSize="12" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="1"
                        Margin="0,0,0,8"
                        Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                        BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="10"
                        Visibility="{Binding HasModuleSuggestion, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ModuleSuggestionMessage}"
                                   TextWrapping="Wrap"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                        <Button Grid.Column="1"
                                Content="{Binding ModuleSuggestionOpenLabel}"
                                Command="{Binding OpenSuggestedModuleCommand}" />
                        <Button Grid.Column="2"
                                Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                Command="{Binding DismissModuleSuggestionCommand}"
                                ToolTipService.ToolTip="Dismiss suggestion"
                                AutomationProperties.Name="Dismiss module suggestion">
                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE711;"
                                      FontSize="12" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="2"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            HorizontalAlignment="Left"
                            Visibility="{Binding IsEditorConnected, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTipService.ToolTip="VS Code integration connected"
                            AutomationProperties.Name="VS Code integration connected">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE943;"
                                      FontSize="12" />
                            <TextBlock Text="VS Code"
                                       Style="{ThemeResource PersonalAiPillTextStyle}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding AttachedContextCount}"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <TextBlock Text="attached"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <Button Command="{Binding ClearAllContextsCommand}"
                                Content="Clear all"
                                Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3"
                      MinWidth="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource PersonalAiIconButtonStyle}"
                            Margin="0,0,12,0"
                            VerticalAlignment="Bottom"
                            ToolTipService.ToolTip="Add context"
                            AutomationProperties.Name="Add context">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE898;"
                                  FontSize="16" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Capture active app"
                                                Command="{Binding CaptureApplicationContextCommand}"
                                                AutomationProperties.Name="Capture active app">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE8B7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Attach clipboard text"
                                                Command="{Binding AttachClipboardContextCommand}"
                                                AutomationProperties.Name="Attach clipboard text">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE8C8;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Capture screenshot"
                                                Command="{Binding CaptureScreenshotContextCommand}"
                                                AutomationProperties.Name="Capture screenshot">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE722;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <TextBox x:Name="PromptTextBox"
                             Grid.Column="1"
                             AcceptsReturn="True"
                             MinWidth="360"
                             MinHeight="84"
                             MaxHeight="160"
                             CornerRadius="14"
                             BorderThickness="0"
                             Background="Transparent"
                             PlaceholderText="Ask anything"
                             Text="{Binding Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Style="{StaticResource PersonalAiPrimaryIconButtonStyle}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding SendMessageCommand}"
                            ToolTipService.ToolTip="Send"
                            AutomationProperties.Name="Send">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE74A;"
                                  FontSize="15" />
                    </Button>
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsTaskCenterVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <StackPanel MinWidth="0"
                                DataContext="{Binding TaskCenter}">
                        <TextBlock Text="Task Center"
                                   Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding SafeStatusMessage}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Command="{Binding TaskCenter.RefreshCommand}"
                                Content="Refresh"
                                ToolTipService.ToolTip="Refresh Task Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,20,0,0"
                  DataContext="{Binding TaskCenter}"
                  ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer>
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource PillCornerRadius}"
                                    Padding="{StaticResource CompactControlPadding}">
                                <TextBlock Text="{Binding ActiveTaskCountText}"
                                           Style="{ThemeResource PersonalAiPillTextStyle}" />
                            </Border>
                            <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource PillCornerRadius}"
                                    Padding="{StaticResource CompactControlPadding}">
                                <TextBlock Text="{Binding WaitingApprovalCountText}"
                                           Style="{ThemeResource PersonalAiPillTextStyle}" />
                            </Border>
                            <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource PillCornerRadius}"
                                    Padding="{StaticResource CompactControlPadding}">
                                <TextBlock Text="{Binding RecentFailureCountText}"
                                           Style="{ThemeResource PersonalAiPillTextStyle}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Waiting for Approval"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No approvals need attention."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoWaitingApprovals, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding WaitingApprovals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding SafeSummary}"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2" />
                                                <TextBlock Text="{Binding Module.Label}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Active Tasks"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No active tasks."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoActiveTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding ActiveTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Command="{Binding DataContext.TaskCenter.SelectTaskCommand, ElementName=Root}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                    BorderThickness="1"
                                                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                    CornerRadius="{StaticResource CardCornerRadius}"
                                                    Padding="{StaticResource CardPadding}"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SafeSummary}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Module.Label}"
                                                               Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Recent Tasks"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No recent task history."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoRecentTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding RecentTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Command="{Binding DataContext.TaskCenter.SelectTaskCommand, ElementName=Root}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                    BorderThickness="1"
                                                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                    CornerRadius="{StaticResource CardCornerRadius}"
                                                    Padding="{StaticResource CardPadding}"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Status.Label}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                    <TextBlock Text="{Binding Module.Label}"
                                                               Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Failed or Cancelled"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No recent failures or cancellations."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoFailedOrCancelledTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding FailedOrCancelledTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding SafeSummary}"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Module.Label}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1"
                        Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                        BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="{StaticResource CardPadding}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedTask.Title}"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedTask.SafeSummary}"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="1"
                                      Margin="0,12,0,0">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Select a task to view timeline."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoTimeline, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding TimelineGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="8"
                                                        Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                <ItemsControl ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                                    BorderThickness="1"
                                                                    Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                                                    CornerRadius="{StaticResource CardCornerRadius}"
                                                                    Padding="{StaticResource CardPadding}"
                                                                    Margin="0,0,0,8">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                                                   TextWrapping="NoWrap"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Status.Label}"
                                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding Summary}"
                                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                                               TextWrapping="Wrap"
                                                                               MaxLines="2" />
                                                                    <TextBlock Text="{Binding Detail}"
                                                                               Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                                               TextWrapping="Wrap"
                                                                               MaxLines="2" />
                                                                    <ItemsControl ItemsSource="{Binding Links}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding Label}"
                                                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                                                           TextWrapping="NoWrap"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsResearchVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Style="{StaticResource PersonalAiWorkspaceCardStyle}">
                <Grid>
                    <StackPanel DataContext="{Binding AedaResearch}">
                        <TextBlock Text="{Binding DisplayName}" Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding ShortDescription}" Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
            <controls:AedaResearchWorkspaceView Grid.Row="1" Margin="0,14,0,0" DataContext="{Binding AedaResearch}" />
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsMemoryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Style="{StaticResource PersonalAiWorkspaceCardStyle}">
                <Grid>
                    <StackPanel DataContext="{Binding AedaMemory}">
                        <TextBlock Text="{Binding DisplayName}" Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding PrivacyStatusText}" Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
            <controls:AedaMemoryWorkspaceView Grid.Row="1" Margin="0,14,0,0" DataContext="{Binding AedaMemory}" />
        </Grid>

        <controls:AedaDashboardView Grid.Column="1"
                                    Visibility="{Binding IsDashboardVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsCodeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel MinWidth="0"
                                Spacing="4"
                                DataContext="{Binding AedaCode}">
                        <TextBlock Text="{Binding DisplayName}"
                                   Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding WorkspaceSummary}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SafeStatusMessage}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="0,6,0,0"
                                    Visibility="{Binding IsWorking, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ProgressRing Width="18"
                                          Height="18"
                                          IsActive="{Binding IsWorking}"
                                          AutomationProperties.Name="{Binding WorkingIndicatorText}" />
                            <TextBlock Text="{Binding WorkingIndicatorText}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Command="{Binding AedaCode.RefreshCommand}"
                                Content="Refresh"
                                AutomationProperties.Name="Refresh AEDA Code workflow" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0"
                          HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Auto">
                <Grid DataContext="{Binding AedaCode}"
                      ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="AedaCodeWorkspaceColumn"
                                          Width="280" />
                        <ColumnDefinition x:Name="AedaCodeMainColumn"
                                          Width="*"
                                          MinWidth="380" />
                        <ColumnDefinition x:Name="AedaCodeWorkflowColumn"
                                          Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup>
                            <VisualState x:Name="AedaCodeNarrowLayout" />
                            <VisualState x:Name="AedaCodeWideLayout">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="1450" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="AedaCodeMainColumn.MinWidth"
                                            Value="560" />
                                    <Setter Target="AedaCodeWorkflowColumn.Width"
                                            Value="340" />
                                    <Setter Target="AedaCodeNarrowWorkflowPanel.Visibility"
                                            Value="Collapsed" />
                                    <Setter Target="AedaCodeWideWorkflowPanel.Visibility"
                                            Value="Visible" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <StackPanel Grid.RowSpan="2"
                                Spacing="16">
                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Workspace"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="{Binding SessionStatusText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding RecentCodeTaskCountText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                <TextBlock Text="No registered workspaces."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoWorkspaces, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding Workspaces}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectWorkspaceCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    Margin="0,0,0,8"
                                                    AutomationProperties.Name="{Binding DisplayName}">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                    <TextBlock Text="{Binding RootSummary}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding PolicyLabel}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="Start session"
                                        Command="{Binding StartSessionCommand}"
                                        HorizontalAlignment="Stretch"
                                        ToolTipService.ToolTip="Start a supervised AEDA Code session for the selected registered workspace." />
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Create Proposal"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="{Binding ProposalCreationWorkspaceText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProposalCreationSafetyText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProposalCreationStateText}"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProposalCreationProgressText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <TextBox Header="Task title"
                                         Text="{Binding ProposalTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="120"
                                         PlaceholderText="Optional"
                                         AutomationProperties.Name="Optional proposal title" />
                                <TextBlock Text="{Binding ProposalTitleLengthText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                <TextBox Header="Coding request"
                                         Text="{Binding ProposalRequest, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="4000"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="112"
                                         PlaceholderText="Describe the exact code change to propose."
                                         AutomationProperties.Name="Coding request" />
                                <TextBlock Text="{Binding ProposalRequestLengthText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Context files"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox PlaceholderText="Search files..."
                                                 Text="{Binding ContextFileSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 AutomationProperties.Name="Search context files" />
                                        <Button Grid.Column="1"
                                                Content="Search"
                                                Command="{Binding SearchContextFilesCommand}"
                                                ToolTipService.ToolTip="Search safe workspace files"
                                                AutomationProperties.Name="Search safe context files" />
                                    </Grid>
                                    <TextBlock Text="{Binding ContextSearchStatusText}"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                               TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding ContextFileCandidates}"
                                                  MaxHeight="170">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="8"
                                                      Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel MinWidth="0">
                                                        <TextBlock Text="{Binding RelativePath}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTipService.ToolTip="{Binding RelativePath}" />
                                                        <TextBlock Text="{Binding SizeLabel}"
                                                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Content="Add"
                                                            Command="{Binding DataContext.AedaCode.AddContextFileCommand, ElementName=Root}"
                                                            CommandParameter="{Binding}"
                                                            ToolTipService.ToolTip="Add file to proposal context"
                                                            AutomationProperties.Name="Add file to context" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Selected context"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{Binding SelectedContextSummaryText}"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                               TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding SelectedContextFiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="8"
                                                      Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel MinWidth="0">
                                                        <TextBlock Text="{Binding RelativePath}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTipService.ToolTip="{Binding RelativePath}" />
                                                        <TextBlock Text="{Binding SizeLabel}"
                                                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Content="x"
                                                            Command="{Binding DataContext.AedaCode.RemoveContextFileCommand, ElementName=Root}"
                                                            CommandParameter="{Binding}"
                                                            ToolTipService.ToolTip="Remove context file"
                                                            AutomationProperties.Name="Remove context file" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                Visibility="{Binding HasSelectedContextFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button Content="Clear context"
                                                Command="{Binding ClearSelectedContextCommand}"
                                                ToolTipService.ToolTip="Clear selected context files"
                                                AutomationProperties.Name="Clear selected context" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding SelectedContextWarningText}"
                                               TextWrapping="Wrap"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                               Visibility="{Binding HasSelectedContextWarning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <StackPanel Spacing="8"
                                                Visibility="{Binding HasSelectedContextFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Target method/snippet"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{Binding TargetSnippetStatusText}"
                                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedTargetSnippetText}"
                                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasSelectedTargetSnippet, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ItemsControl ItemsSource="{Binding TargetSnippetCandidates}"
                                                      MaxHeight="210">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnSpacing="8"
                                                          Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel MinWidth="0"
                                                                    Spacing="2">
                                                            <TextBlock Text="{Binding SignaturePreview}"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTipService.ToolTip="{Binding SignaturePreview}" />
                                                            <TextBlock Text="{Binding SafePreview}"
                                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Style="{ThemeResource PersonalAiSecondaryTextStyle}">
                                                                <Run Text="Line " />
                                                                <Run Text="{Binding StartLine}" />
                                                                <Run Text=" - " />
                                                                <Run Text="{Binding LineCount}" />
                                                                <Run Text=" lines" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="Use"
                                                                Command="{Binding DataContext.AedaCode.SelectTargetSnippetCommand, ElementName=Root}"
                                                                CommandParameter="{Binding}"
                                                                ToolTipService.ToolTip="Use this exact snippet as the proposal target"
                                                                AutomationProperties.Name="Use target snippet" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="Clear target"
                                                Command="{Binding ClearTargetSnippetCommand}"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding HasSelectedTargetSnippet, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                ToolTipService.ToolTip="Clear selected target snippet"
                                                AutomationProperties.Name="Clear target snippet" />
                                    </StackPanel>
                                </StackPanel>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Create proposal"
                                            Command="{Binding CreateProposalCommand}"
                                            HorizontalAlignment="Stretch" />
                                    <Button Grid.Column="1"
                                            Content="Cancel"
                                            Command="{Binding CancelProposalCreationCommand}"
                                            HorizontalAlignment="Stretch" />
                                </Grid>
                                <TextBlock Text="{Binding SafeStatusMessage}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <StackPanel Spacing="4"
                                            Visibility="{Binding HasProposalCreationFailure, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding ProposalCreationFailureText}"
                                               TextWrapping="Wrap"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{Binding ProposalCreationFailureDetailText}"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                               TextWrapping="Wrap" />
                                    <Button Content="Retry proposal"
                                            Command="{Binding CreateProposalCommand}"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.Name="Retry proposal" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Proposals"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="{Binding ProposalCountText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                <TextBlock Text="No proposals for this workspace."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoProposals, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding Proposals}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectProposalCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    Margin="0,0,0,8"
                                                    AutomationProperties.Name="{Binding Title}">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{Binding Title}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                    <TextBlock Text="{Binding SafeSummary}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Style="{ThemeResource PersonalAiSecondaryTextStyle}">
                                                        <Run Text="{Binding Status}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding RiskLabel}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding AffectedFileCount}" />
                                                        <Run Text=" files" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding UpdatedText}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                </StackPanel>
