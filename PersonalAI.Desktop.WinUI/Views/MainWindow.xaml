                                       TextWrapping="Wrap"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Add workspace"
                                        Command="{Binding PickWorkspaceFolderCommand}"
                                        AutomationProperties.Name="Add workspace folder" />
                                <Button Content="Revalidate all"
                                        Command="{Binding RevalidateAllCommand}" />
                                <Button Content="Refresh list"
                                        Command="{Binding RefreshCommand}" />
                                <ProgressRing Width="20"
                                              Height="20"
                                              IsActive="{Binding IsBusy}" />
                                <TextBlock Text="{Binding BusyMessage}"
                                           VerticalAlignment="Center"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                <TextBlock Text="{Binding StatusMessage}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
