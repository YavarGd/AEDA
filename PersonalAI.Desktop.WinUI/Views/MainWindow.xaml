<Window
    x:Class="PersonalAI.Desktop.WinUI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PersonalAI.Desktop.WinUI.Controls"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters"
    Title="PersonalAI">
    <Grid x:Name="Root"
          KeyDown="Root_KeyDown"
          MinWidth="1080"
          MinHeight="760"
          Background="{ThemeResource PersonalAiPageBackgroundBrush}">
        <Grid.Resources>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:ChatRoleSurfaceBrushConverter x:Key="ChatRoleSurfaceBrushConverter" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarColumnWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              MinWidth="240"
              MaxWidth="280"
              Padding="{Binding SidebarPadding}"
              Background="{ThemeResource PersonalAiSidebarBackgroundBrush}"
              BorderBrush="{ThemeResource PersonalAiBorderBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel MinWidth="0">
                    <TextBlock Text="PersonalAI"
                               Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="Local assistant"
                               Style="{ThemeResource PersonalAiMetadataTextStyle}"
                               TextWrapping="NoWrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource PersonalAiIconButtonStyle}"
                        Command="{Binding NewChatCommand}"
                        ToolTipService.ToolTip="New chat"
                        AutomationProperties.Name="New chat">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE710;"
                              FontSize="16" />
                </Button>
            </Grid>

            <TextBox Grid.Row="1"
                     Margin="0,0,0,12"
                     MinWidth="0"
                     PlaceholderText="Search conversations"
                     Text="{Binding ConversationSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="2"
                       Text="Conversations"
                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                       Margin="4,0,0,8" />
            <ListView Grid.Row="3"
                      ItemsSource="{Binding Conversations}"
                      SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                      SelectionChanged="ConversationList_SelectionChanged"
                      HorizontalContentAlignment="Stretch">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="2"
                                    MinWidth="0"
                                    Padding="4,6">
                            <TextBlock Text="{Binding Title}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{Binding Title}" />
                            <TextBlock Text="{Binding Preview}"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                       TextWrapping="NoWrap"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding DataContext.ShowConversationMetadata, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock Grid.Row="3"
                       Text="No conversations yet"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                       Visibility="{Binding HasNoConversations, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button Grid.Row="4"
                    Style="{StaticResource PersonalAiIconButtonStyle}"
                    HorizontalAlignment="Left"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTipService.ToolTip="Settings"
                    AutomationProperties.Name="Settings">
                <FontIcon FontFamily="Segoe MDL2 Assets"
                          Glyph="&#xE713;"
                          FontSize="16" />
            </Button>
        </Grid>

        <Grid Grid.Column="1"
              MinWidth="760"
              Padding="{StaticResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel MinWidth="0">
                    <TextBlock Text="{Binding CurrentConversationTitle}"
                               Style="{ThemeResource PersonalAiPageTitleTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}">
                        <TextBlock Text="Local"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            MaxWidth="220"
                            Visibility="{Binding HasConversationModelOverride, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTipService.ToolTip="{Binding ConversationModelOverrideLabel}">
                        <TextBlock Text="{Binding ConversationModelOverrideLabel}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            MaxWidth="260"
                            ToolTipService.ToolTip="{Binding RoutingStatusMessage}">
                        <TextBlock Text="{Binding RoutingStatusMessage}"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                </StackPanel>

                <ProgressRing Grid.Column="2"
                              Width="28"
                              Height="28"
                              IsActive="{Binding IsGenerating}" />
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,20,0,16"
                  MinWidth="0">
                <ListView x:Name="TimelineList"
                          ItemsSource="{Binding Messages}"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Top">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight"
                                    Value="0" />
                            <Setter Property="VerticalContentAlignment"
                                    Value="Top" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,8"
                                  MinWidth="0"
                                  VerticalAlignment="Top">
                                <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="{Binding BorderThickness}"
                                        CornerRadius="{Binding CornerRadius}"
                                        Background="{Binding Role, Converter={StaticResource ChatRoleSurfaceBrushConverter}}"
                                        Padding="{Binding Padding}"
                                        MaxWidth="{Binding MessageMaxWidth}"
                                        HorizontalAlignment="{Binding MessageHorizontalAlignment}">
                                    <StackPanel MinWidth="0">
                                        <TextBlock Text="{Binding MetadataText}"
                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                   Visibility="{Binding DataContext.ShowMessageMetadata, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="{Binding ContentTextWrapping}"
                                                   TextTrimming="{Binding ContentTextTrimming}"
                                                   MaxLines="{Binding ContentMaxLines}"
                                                   ToolTipService.ToolTip="{Binding Content}"
                                                   IsTextSelectionEnabled="True"
                                                   Visibility="{Binding UsesPlainTextPresenter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <controls:ChatMarkdownPresenter Content="{Binding RenderedContent}"
                                                                        Visibility="{Binding UsesMarkdownPresenter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6"
                                                    Margin="0,8,0,0">
                                            <Button Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                                    Command="{Binding DataContext.CopyMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    ToolTipService.ToolTip="Copy message"
                                                    AutomationProperties.Name="Copy message">
                                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                                          Glyph="&#xE8C8;"
                                                          FontSize="12" />
                                            </Button>
                                            <Button Content="Regenerate"
                                                    Command="{Binding DataContext.RegenerateMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanRegenerate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Retry"
                                                    Command="{Binding DataContext.RetryMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanRetry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Use automatic routing"
                                                    Command="{Binding DataContext.UseAutomaticRoutingCommand, ElementName=Root}"
                                                    Visibility="{Binding IsCapabilityBlocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Choose vision model"
                                                    Command="{Binding DataContext.ChooseVisionModelCommand, ElementName=Root}"
                                                    Visibility="{Binding IsCapabilityBlocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button x:Name="JumpToLatestButton"
                        Content="Jump to latest"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,12"
                        Visibility="Collapsed"
                        Click="JumpToLatestButton_Click"
                        ToolTipService.ToolTip="Jump to latest"
                        AutomationProperties.Name="Jump to latest" />
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Visibility="{Binding IsTimelineEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE8A5;"
                              FontSize="28"
                              Foreground="{ThemeResource PersonalAiMutedTextBrush}" />
                    <TextBlock Text="Start a conversation"
                               Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Ask a question or attach context from the composer."
                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ComposerCornerRadius}"
                    Padding="12"
                    MinWidth="0">
                <Grid MinWidth="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0"
                              Margin="0,0,0,8"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding AttachedContexts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CardCornerRadius}"
                                        Padding="8"
                                        Margin="0,0,8,0"
                                        Width="184"
                                        Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                        ToolTipService.ToolTip="{Binding Preview}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE722;"
                                                  FontSize="16"
                                                  Margin="0,2,8,0"
                                                  Foreground="{ThemeResource PersonalAiSecondaryTextBrush}" />

                                        <StackPanel Grid.Column="1"
                                                    Spacing="1"
                                                    MinWidth="0">
                                            <TextBlock Text="{Binding DisplayTitle}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding SourceName}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Top"
                                                Command="{Binding DataContext.RemoveContextCommand, ElementName=Root}"
                                                CommandParameter="{Binding}"
                                                ToolTipService.ToolTip="Remove context"
                                                AutomationProperties.Name="Remove context">
                                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                                      Glyph="&#xE711;"
                                                      FontSize="12" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="1"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            HorizontalAlignment="Left"
                            Visibility="{Binding IsEditorConnected, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTipService.ToolTip="VS Code integration connected"
                            AutomationProperties.Name="VS Code integration connected">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE943;"
                                      FontSize="12" />
                            <TextBlock Text="VS Code"
                                       Style="{ThemeResource PersonalAiPillTextStyle}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding AttachedContextCount}"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <TextBlock Text="attached"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <Button Command="{Binding ClearAllContextsCommand}"
                                Content="Clear all"
                                Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2"
                      MinWidth="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource PersonalAiIconButtonStyle}"
                            Margin="0,0,12,0"
                            VerticalAlignment="Bottom"
                            ToolTipService.ToolTip="Add context"
                            AutomationProperties.Name="Add context">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE898;"
                                  FontSize="16" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Capture active app"
                                                Command="{Binding CaptureApplicationContextCommand}"
                                                AutomationProperties.Name="Capture active app">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE8B7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Attach clipboard text"
                                                Command="{Binding AttachClipboardContextCommand}"
                                                AutomationProperties.Name="Attach clipboard text">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE8C8;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Capture screenshot"
                                                Command="{Binding CaptureScreenshotContextCommand}"
                                                AutomationProperties.Name="Capture screenshot">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE722;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <TextBox x:Name="PromptTextBox"
                             Grid.Column="1"
                             AcceptsReturn="True"
                             MinWidth="360"
                             MinHeight="84"
                             MaxHeight="160"
                             PlaceholderText="Ask anything"
                             Text="{Binding Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Style="{StaticResource PersonalAiIconButtonStyle}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding SendMessageCommand}"
                            ToolTipService.ToolTip="Send"
                            AutomationProperties.Name="Send">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE74A;"
                                  FontSize="16" />
                    </Button>
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <TextBlock Text="Settings"
                           Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                <Button HorizontalAlignment="Right"
                        Command="{Binding CloseSettingsCommand}"
                        Content="Done" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0">
                <StackPanel DataContext="{Binding Settings}"
                            MaxWidth="800"
                            Spacing="8"
                            HorizontalAlignment="Left">
                    <Expander Header="General"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Launch destination"
                                      ItemsSource="{Binding LaunchDestinationOptions}"
                                      SelectedItem="{Binding LaunchDestination, Mode=TwoWay}" />
                            <CheckBox Content="Preserve composer draft between hide/show"
                                      IsChecked="{Binding PreserveComposerDraftBetweenHideShow, Mode=TwoWay}" />
                            <CheckBox Content="Confirm before clearing all attached context"
                                      IsChecked="{Binding ConfirmBeforeClearingAllContext, Mode=TwoWay}" />
                            <TextBlock Text="{Binding SettingsPath}"
                                       TextWrapping="Wrap"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Workspaces"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="True">
                        <StackPanel x:Name="WorkspaceManagementPanel"
                                    DataContext="{Binding Workspaces}"
                                    Spacing="12">
                            <TextBlock Text="Workspaces"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="Only folders you explicitly register here are available to workspace tools. Current tools are read-only and ask for permission before reading."
                                       TextWrapping="Wrap"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Add workspace"
                                        Command="{Binding PickWorkspaceFolderCommand}"
                                        AutomationProperties.Name="Add workspace folder" />
                                <Button Content="Revalidate all"
                                        Command="{Binding RevalidateAllCommand}" />
                                <Button Content="Refresh list"
                                        Command="{Binding RefreshCommand}" />
                                <ProgressRing Width="20"
                                              Height="20"
                                              IsActive="{Binding IsBusy}" />
                                <TextBlock Text="{Binding BusyMessage}"
                                           VerticalAlignment="Center"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                <TextBlock Text="{Binding StatusMessage}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                    BorderThickness="1"
                                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                    CornerRadius="{StaticResource CardCornerRadius}"
                                    Padding="{StaticResource CardPadding}"
                                    Visibility="{Binding HasPendingWorkspace, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Review workspace"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBox Header="Selected folder"
                                             Text="{Binding PendingFolderPath}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap" />
                                    <TextBox Header="Display name"
                                             Text="{Binding PendingDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Workspace tools may request permission to read files in this folder. Current workspace tools are read-only and cannot change files. Symlinks and junctions are rejected."
                                               TextWrapping="Wrap"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="Add workspace"
                                                Command="{Binding AddPendingWorkspaceCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding CancelPendingWorkspaceCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="No workspaces registered."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoWorkspaces, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Workspaces}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                        <TextBlock Text="{Binding ShortRootPath}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                                   ToolTipService.ToolTip="{Binding RootPath}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource PillCornerRadius}"
                                                            Padding="{StaticResource CompactControlPadding}"
                                                            Margin="12,0,0,0">
                                                        <TextBlock Text="{Binding ReadOnlyBadge}"
                                                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                                                    </Border>
                                                </Grid>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <TextBlock Text="{Binding StatusSymbol}" />
                                                    <TextBlock Text="{Binding Status}" />
                                                    <TextBlock Text="{Binding StatusDetail}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                </StackPanel>
                                                <Expander Header="Details"
                                                          IsExpanded="False">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{Binding WorkspaceId}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Source}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                        <TextBlock Text="{Binding AddedAt}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                        <TextBlock Text="{Binding LastValidated}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                    </StackPanel>
                                                </Expander>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Button Content="Rename"
                                                            Command="{Binding DataContext.RenameWorkspaceCommand, ElementName=WorkspaceManagementPanel}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Revalidate"
                                                            Command="{Binding DataContext.RevalidateWorkspaceCommand, ElementName=WorkspaceManagementPanel}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Remove"
                                                            Command="{Binding DataContext.RemoveWorkspaceCommand, ElementName=WorkspaceManagementPanel}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Appearance"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="True">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Theme"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding Theme, Mode=TwoWay}" />
                            <CheckBox Content="Compact sidebar"
                                      IsChecked="{Binding CompactSidebar, Mode=TwoWay}" />
                            <CheckBox Content="Show message metadata"
                                      IsChecked="{Binding ShowMessageMetadata, Mode=TwoWay}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Models"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Refresh models"
                                        Command="{Binding RefreshModelsCommand}" />
                                <Button Content="Reset assignments"
                                        Command="{Binding ResetModelAssignmentsCommand}" />
                                <TextBlock Text="{Binding ModelRefreshStatus}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            </StackPanel>
                            <ComboBox Header="General"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding GeneralModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Coding"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding CodingModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Vision"
                                      ItemsSource="{Binding VisionModels}"
                                      SelectedItem="{Binding VisionModel, Mode=TwoWay}"
                                      IsEditable="False" />
                            <ComboBox Header="Fast"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding FastModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Reasoning"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding ReasoningModel, Mode=TwoWay}"
                                      IsEditable="True" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Integrations"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12">
                                <CheckBox Content="Ctrl"
                                          IsChecked="{Binding HotkeyControl, Mode=TwoWay}" />
                                <CheckBox Content="Alt"
                                          IsChecked="{Binding HotkeyAlt, Mode=TwoWay}" />
                                <CheckBox Content="Shift"
                                          IsChecked="{Binding HotkeyShift, Mode=TwoWay}" />
                                <CheckBox Content="Win"
                                          IsChecked="{Binding HotkeyWindows, Mode=TwoWay}" />
                            </StackPanel>
                            <TextBox Header="Key"
                                     Text="{Binding HotkeyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Apply hotkey"
                                        Command="{Binding ApplyHotkeyCommand}" />
                                <Button Content="Reset hotkey"
                                        Command="{Binding ResetHotkeyCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Window and startup"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Close behavior"
                                      ItemsSource="{Binding CloseBehaviorOptions}"
                                      SelectedItem="{Binding CloseBehavior, Mode=TwoWay}" />
                            <CheckBox Content="Start minimized to tray"
                                      IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}" />
                            <CheckBox Content="Remember window position"
                                      IsChecked="{Binding RememberWindowPosition, Mode=TwoWay}" />
                            <CheckBox Content="Launch at Windows sign-in"
                                      IsChecked="{Binding LaunchAtSignIn, Mode=TwoWay}" />
                            <Button Content="Apply startup setting"
                                    Command="{Binding ToggleStartupCommand}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Privacy"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <NumberBox Header="Max total text context characters"
                                       Value="{Binding MaxTotalTextContextCharacters, Mode=TwoWay}" />
                            <NumberBox Header="Max clipboard attachment characters"
                                       Value="{Binding MaxIndividualClipboardCharacters, Mode=TwoWay}" />
                            <NumberBox Header="Max attached context items"
                                       Value="{Binding MaxAttachedContextItems, Mode=TwoWay}" />
                            <NumberBox Header="Screenshot max payload bytes"
                                       Value="{Binding ScreenshotMaxPayloadBytes, Mode=TwoWay}" />
                            <NumberBox Header="Screenshot thumbnail max edge"
                                       Value="{Binding ScreenshotThumbnailMaxEdge, Mode=TwoWay}" />
                            <CheckBox Content="Clear attachments after successful send"
                                      IsChecked="{Binding ClearAttachmentsAfterSuccessfulSend, Mode=TwoWay}" />
                            <CheckBox Content="Include executable path in provider metadata"
                                      IsChecked="{Binding IncludeExecutablePathInProviderMetadata, Mode=TwoWay}" />
                            <CheckBox Content="Include window title in provider context"
                                      IsChecked="{Binding IncludeWindowTitleInProviderContext, Mode=TwoWay}" />
                            <TextBox Header="Excluded applications (one process name per line)"
                                     AcceptsReturn="True"
                                     MinHeight="120"
                                     Text="{Binding ExcludedApplicationsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Developer diagnostics"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <TextBox Header="Additional vision model patterns"
                                     AcceptsReturn="True"
                                     MinHeight="96"
                                     Text="{Binding VisionPatternsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding SchemaVersionDisplay}"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Open settings folder"
                                        Command="{Binding OpenSettingsFolderCommand}" />
                                <Button Content="Reset window position"
                                        Command="{Binding ResetWindowPositionCommand}" />
                            </StackPanel>
                            <Button Content="Reset all settings"
                                    Command="{Binding ResetAllCommand}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Developer"
                              IsExpanded="False"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              DataContext="{Binding DataContext, ElementName=Root}"
                              Visibility="{Binding IsDeveloperDiagnosticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Developer workspace tools"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            <Button Content="Run UTC reference tool"
                                    HorizontalAlignment="Left"
                                    Command="{Binding RunReferenceToolCommand}" />
                            <TextBox PlaceholderText="Registered workspace ID from Settings"
                                     Text="{Binding DeveloperWorkspaceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="220"
                                         PlaceholderText="Relative path"
                                         Text="{Binding DeveloperToolPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="List"
                                        Command="{Binding RunDeveloperListDirectoryCommand}" />
                                <Button Content="Read"
                                        Command="{Binding RunDeveloperReadFileCommand}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="360"
                                         PlaceholderText="Literal search query"
                                         Text="{Binding DeveloperSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="Search"
                                        Command="{Binding RunDeveloperSearchWorkspaceCommand}" />
                            </StackPanel>
                            <TextBlock Text="{Binding DeveloperToolResult}"
                                       TextWrapping="Wrap"
                                       MaxHeight="120"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
