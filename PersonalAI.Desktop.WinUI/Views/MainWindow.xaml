                                    Padding="{StaticResource CardPadding}"
                                    Visibility="{Binding HasPendingWorkspace, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Review workspace"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBox Header="Selected folder"
                                             Text="{Binding PendingFolderPath}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap" />
                                    <TextBox Header="Display name"
                                             Text="{Binding PendingDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Workspace tools may request permission to read files in this folder. Current workspace tools are read-only and cannot change files. Symlinks and junctions are rejected."
                                               TextWrapping="Wrap"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="Add workspace"
                                                Command="{Binding AddPendingWorkspaceCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding CancelPendingWorkspaceCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="No workspaces registered."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoWorkspaces, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Workspaces}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                        <TextBlock Text="{Binding ShortRootPath}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                                   ToolTipService.ToolTip="{Binding RootPath}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource PillCornerRadius}"
                                                            Padding="{StaticResource CompactControlPadding}"
                                                            Margin="12,0,0,0">
                                                        <TextBlock Text="{Binding ReadOnlyBadge}"
                                                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                                                    </Border>
                                                </Grid>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <TextBlock Text="{Binding StatusSymbol}" />
                                                    <TextBlock Text="{Binding Status}" />
                                                    <TextBlock Text="{Binding StatusDetail}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                </StackPanel>
                                                <Expander Header="Details"
                                                          IsExpanded="False">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{Binding WorkspaceId}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Source}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                        <TextBlock Text="{Binding AddedAt}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                        <TextBlock Text="{Binding LastValidated}"
                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                    </StackPanel>
                                                </Expander>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Button Content="Rename"
                                                            Command="{Binding DataContext.RenameWorkspaceCommand, ElementName=WorkspaceManagementPanel}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Revalidate"
                                                            Command="{Binding DataContext.RevalidateWorkspaceCommand, ElementName=WorkspaceManagementPanel}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Remove"
                                                            Command="{Binding DataContext.RemoveWorkspaceCommand, ElementName=WorkspaceManagementPanel}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Appearance"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              Visibility="Collapsed"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Theme"
                                      ItemsSource="{Binding ThemeOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding Theme, Mode=TwoWay}" />
                            <CheckBox Content="Compact sidebar"
                                      IsChecked="{Binding CompactSidebar, Mode=TwoWay}" />
                            <CheckBox Content="Show message metadata"
                                      IsChecked="{Binding ShowMessageMetadata, Mode=TwoWay}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Models"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Refresh models"
                                        Command="{Binding RefreshModelsCommand}" />
                                <Button Content="Reset assignments"
                                        Command="{Binding ResetModelAssignmentsCommand}" />
                                <TextBlock Text="{Binding ModelRefreshStatus}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            </StackPanel>
                            <ComboBox Header="General"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding GeneralModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Coding"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding CodingModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Vision"
                                      ItemsSource="{Binding VisionModels}"
                                      SelectedItem="{Binding VisionModel, Mode=TwoWay}"
                                      IsEditable="False" />
                            <ComboBox Header="Fast"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding FastModel, Mode=TwoWay}"
                                      IsEditable="True" />
                            <ComboBox Header="Reasoning"
                                      ItemsSource="{Binding InstalledModels}"
                                      SelectedItem="{Binding ReasoningModel, Mode=TwoWay}"
                                      IsEditable="True" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Integrations"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12">
                                <CheckBox Content="Ctrl"
                                          IsChecked="{Binding HotkeyControl, Mode=TwoWay}" />
                                <CheckBox Content="Alt"
                                          IsChecked="{Binding HotkeyAlt, Mode=TwoWay}" />
                                <CheckBox Content="Shift"
                                          IsChecked="{Binding HotkeyShift, Mode=TwoWay}" />
                                <CheckBox Content="Win"
                                          IsChecked="{Binding HotkeyWindows, Mode=TwoWay}" />
                            </StackPanel>
                            <TextBox Header="Key"
                                     Text="{Binding HotkeyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Apply hotkey"
                                        Command="{Binding ApplyHotkeyCommand}" />
                                <Button Content="Reset hotkey"
                                        Command="{Binding ResetHotkeyCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Window and startup"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <ComboBox Header="Close behavior"
                                      ItemsSource="{Binding CloseBehaviorOptions}"
                                      SelectedItem="{Binding CloseBehavior, Mode=TwoWay}" />
                            <CheckBox Content="Start minimized to tray"
                                      IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}" />
                            <CheckBox Content="Remember window position"
                                      IsChecked="{Binding RememberWindowPosition, Mode=TwoWay}" />
                            <CheckBox Content="Launch at Windows sign-in"
                                      IsChecked="{Binding LaunchAtSignIn, Mode=TwoWay}" />
                            <Button Content="Apply startup setting"
                                    Command="{Binding ToggleStartupCommand}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="AEDA Assist"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <CheckBox Content="Show the AEDA Assist pill"
                                      IsChecked="{Binding AssistPillEnabled, Mode=TwoWay}" />
                            <CheckBox Content="Universal selection fallback"
                                      IsChecked="{Binding UniversalSelectionFallbackEnabled, Mode=TwoWay}" />
                            <TextBlock Text="AEDA can temporarily use Copy to read your current selection when an app does not expose it through Windows accessibility. Your previous clipboard is restored when possible."
                                       TextWrapping="Wrap"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            <NumberBox Header="Response preview characters"
                                       Minimum="200"
                                       Maximum="4000"
                                       SmallChange="100"
                                       Value="{Binding AssistPillResponsePreviewCharacters, Mode=TwoWay}" />
                            <TextBlock Text="The full response remains available in AEDA Chat."
                                       TextWrapping="Wrap"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Privacy"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <NumberBox Header="Max total text context characters"
                                       Value="{Binding MaxTotalTextContextCharacters, Mode=TwoWay}" />
                            <NumberBox Header="Max clipboard attachment characters"
                                       Value="{Binding MaxIndividualClipboardCharacters, Mode=TwoWay}" />
                            <NumberBox Header="Max attached context items"
                                       Value="{Binding MaxAttachedContextItems, Mode=TwoWay}" />
                            <NumberBox Header="Screenshot max payload bytes"
                                       Value="{Binding ScreenshotMaxPayloadBytes, Mode=TwoWay}" />
                            <NumberBox Header="Screenshot thumbnail max edge"
                                       Value="{Binding ScreenshotThumbnailMaxEdge, Mode=TwoWay}" />
                            <CheckBox Content="Clear attachments after successful send"
                                      IsChecked="{Binding ClearAttachmentsAfterSuccessfulSend, Mode=TwoWay}" />
                            <CheckBox Content="Include executable path in provider metadata"
                                      IsChecked="{Binding IncludeExecutablePathInProviderMetadata, Mode=TwoWay}" />
                            <CheckBox Content="Include window title in provider context"
                                      IsChecked="{Binding IncludeWindowTitleInProviderContext, Mode=TwoWay}" />
                            <TextBox Header="Excluded applications (one process name per line)"
                                     AcceptsReturn="True"
                                     MinHeight="120"
                                     Text="{Binding ExcludedApplicationsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Developer diagnostics"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              IsExpanded="False">
                        <StackPanel Spacing="12">
                            <TextBox Header="Additional vision model patterns"
                                     AcceptsReturn="True"
                                     MinHeight="96"
                                     Text="{Binding VisionPatternsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding SchemaVersionDisplay}"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Open settings folder"
                                        Command="{Binding OpenSettingsFolderCommand}" />
                                <Button Content="Reset window position"
                                        Command="{Binding ResetWindowPositionCommand}" />
                            </StackPanel>
                            <Button Content="Reset all settings"
                                    Command="{Binding ResetAllCommand}" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Developer"
                              IsExpanded="False"
                              Style="{ThemeResource PersonalAiSettingsExpanderStyle}"
                              DataContext="{Binding DataContext, ElementName=Root}"
                              Visibility="{Binding IsDeveloperDiagnosticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Developer workspace tools"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            <Button Content="Run UTC reference tool"
                                    HorizontalAlignment="Left"
                                    Command="{Binding RunReferenceToolCommand}" />
                            <TextBox PlaceholderText="Registered workspace ID from Settings"
                                     Text="{Binding DeveloperWorkspaceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="220"
                                         PlaceholderText="Relative path"
                                         Text="{Binding DeveloperToolPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="List"
                                        Command="{Binding RunDeveloperListDirectoryCommand}" />
                                <Button Content="Read"
                                        Command="{Binding RunDeveloperReadFileCommand}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="360"
                                         PlaceholderText="Literal search query"
                                         Text="{Binding DeveloperSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="Search"
                                        Command="{Binding RunDeveloperSearchWorkspaceCommand}" />
                            </StackPanel>
                            <TextBlock Text="{Binding DeveloperToolResult}"
                                       TextWrapping="Wrap"
                                       MaxHeight="120"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        </Grid>
    </Grid>
</Window>
