<Window
    x:Class="PersonalAI.Desktop.WinUI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PersonalAI.Desktop.WinUI.Controls"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters"
    Title="PersonalAI">
    <Grid x:Name="Root"
          KeyDown="Root_KeyDown"
          MinWidth="1080"
          MinHeight="760"
          Background="{ThemeResource PersonalAiPageBackgroundBrush}">
        <Grid.Resources>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:ChatRoleSurfaceBrushConverter x:Key="ChatRoleSurfaceBrushConverter" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarColumnWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              MinWidth="240"
              MaxWidth="280"
              Margin="12,12,6,12"
              Padding="{Binding SidebarPadding}"
              CornerRadius="{StaticResource SidebarCornerRadius}"
              Background="{ThemeResource PersonalAiSidebarBackgroundBrush}"
              BorderBrush="{ThemeResource PersonalAiBorderBrush}"
              BorderThickness="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel MinWidth="0"
                            Spacing="2">
                    <TextBlock Text="PersonalAI"
                               Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="Local assistant"
                               Style="{ThemeResource PersonalAiMetadataTextStyle}"
                               TextWrapping="NoWrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource PersonalAiIconButtonStyle}"
                        Command="{Binding NewChatCommand}"
                        ToolTipService.ToolTip="New chat"
                        AutomationProperties.Name="New chat">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE710;"
                              FontSize="16" />
                </Button>
            </Grid>

            <TextBox Grid.Row="1"
                     Margin="0,0,0,16"
                     MinWidth="0"
                     CornerRadius="10"
                     PlaceholderText="Search conversations"
                     Text="{Binding ConversationSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="2"
                       Text="CONVERSATIONS"
                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                       CharacterSpacing="20"
                       Margin="4,0,0,10" />
            <ListView Grid.Row="3"
                      ItemsSource="{Binding Conversations}"
                      SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                      SelectionChanged="ConversationList_SelectionChanged"
                      Padding="0,0,0,8"
                      HorizontalContentAlignment="Stretch">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0,0,0,3" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="CornerRadius" Value="10" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="2"
                                    MinWidth="0"
                                    Padding="10,8">
                            <TextBlock Text="{Binding Title}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{Binding Title}" />
                            <TextBlock Text="{Binding Preview}"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                       TextWrapping="NoWrap"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding DataContext.ShowConversationMetadata, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock Grid.Row="3"
                       Text="No conversations yet"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                       Visibility="{Binding HasNoConversations, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,12,0,0">
                <Button Style="{StaticResource PersonalAiIconButtonStyle}"
                        Command="{Binding OpenDashboardCommand}"
                        ToolTipService.ToolTip="Module dashboard"
                        AutomationProperties.Name="Module dashboard">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE80F;"
                              FontSize="16" />
                </Button>
                <Button Style="{StaticResource PersonalAiIconButtonStyle}"
                        Command="{Binding OpenTaskCenterCommand}"
                        ToolTipService.ToolTip="Task Center"
                        AutomationProperties.Name="Task Center">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE9D9;"
                              FontSize="16" />
                </Button>
                <Button Style="{StaticResource PersonalAiIconButtonStyle}"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTipService.ToolTip="Settings"
                        AutomationProperties.Name="Settings">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE713;"
                              FontSize="16" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1"
              MinWidth="760"
              Padding="{StaticResource PagePadding}"
              Visibility="{Binding IsChatVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel MinWidth="0">
                    <TextBlock Text="{Binding CurrentConversationTitle}"
                               Style="{ThemeResource PersonalAiPageTitleTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}">
                        <TextBlock Text="Local"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            MaxWidth="220"
                            Visibility="{Binding HasConversationModelOverride, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTipService.ToolTip="{Binding ConversationModelOverrideLabel}">
                        <TextBlock Text="{Binding ConversationModelOverrideLabel}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            MaxWidth="260"
                            ToolTipService.ToolTip="{Binding RoutingStatusMessage}">
                        <TextBlock Text="{Binding RoutingStatusMessage}"
                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                    </Border>
                </StackPanel>

                <ProgressRing Grid.Column="2"
                              Width="28"
                              Height="28"
                              IsActive="{Binding IsGenerating}" />
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,20,0,16"
                  MinWidth="0">
                <ListView x:Name="TimelineList"
                          ItemsSource="{Binding Messages}"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Top">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight"
                                    Value="0" />
                            <Setter Property="VerticalContentAlignment"
                                    Value="Top" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,8"
                                  MinWidth="0"
                                  VerticalAlignment="Top">
                                <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="{Binding BorderThickness}"
                                        CornerRadius="{Binding CornerRadius}"
                                        Background="{Binding Role, Converter={StaticResource ChatRoleSurfaceBrushConverter}}"
                                        Padding="{Binding Padding}"
                                        MaxWidth="{Binding MessageMaxWidth}"
                                        HorizontalAlignment="{Binding MessageHorizontalAlignment}">
                                    <StackPanel MinWidth="0">
                                        <TextBlock Text="{Binding MetadataText}"
                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                   Visibility="{Binding DataContext.ShowMessageMetadata, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="{Binding ContentTextWrapping}"
                                                   TextTrimming="{Binding ContentTextTrimming}"
                                                   MaxLines="{Binding ContentMaxLines}"
                                                   ToolTipService.ToolTip="{Binding Content}"
                                                   IsTextSelectionEnabled="True"
                                                   Visibility="{Binding UsesPlainTextPresenter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <controls:ChatMarkdownPresenter Content="{Binding RenderedContent}"
                                                                        Visibility="{Binding UsesMarkdownPresenter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6"
                                                    Margin="0,8,0,0">
                                            <Button Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                                    Command="{Binding DataContext.CopyMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    ToolTipService.ToolTip="Copy message"
                                                    AutomationProperties.Name="Copy message">
                                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                                          Glyph="&#xE8C8;"
                                                          FontSize="12" />
                                            </Button>
                                            <Button Content="Regenerate"
                                                    Command="{Binding DataContext.RegenerateMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanRegenerate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Retry"
                                                    Command="{Binding DataContext.RetryMessageCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanRetry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Use automatic routing"
                                                    Command="{Binding DataContext.UseAutomaticRoutingCommand, ElementName=Root}"
                                                    Visibility="{Binding IsCapabilityBlocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Choose vision model"
                                                    Command="{Binding DataContext.ChooseVisionModelCommand, ElementName=Root}"
                                                    Visibility="{Binding IsCapabilityBlocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button x:Name="JumpToLatestButton"
                        Content="Jump to latest"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,16"
                        Padding="16,8"
                        CornerRadius="{StaticResource PillCornerRadius}"
                        Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                        BorderBrush="{ThemeResource PersonalAiStrongBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        Click="JumpToLatestButton_Click"
                        ToolTipService.ToolTip="Jump to latest"
                        AutomationProperties.Name="Jump to latest" />
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Visibility="{Binding IsTimelineEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="56"
                            Height="56"
                            CornerRadius="28"
                            Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            HorizontalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE8A5;"
                                  FontSize="22"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource PersonalAiMutedTextBrush}" />
                    </Border>
                    <TextBlock Text="Start a conversation"
                               Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Ask a question or attach context from the composer."
                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ComposerCornerRadius}"
                    Padding="16,14"
                    MinWidth="0">
                <Grid MinWidth="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0"
                              Margin="0,0,0,8"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding AttachedContexts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CardCornerRadius}"
                                        Padding="8"
                                        Margin="0,0,8,0"
                                        Width="184"
                                        Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                        ToolTipService.ToolTip="{Binding Preview}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE722;"
                                                  FontSize="16"
                                                  Margin="0,2,8,0"
                                                  Foreground="{ThemeResource PersonalAiSecondaryTextBrush}" />

                                        <StackPanel Grid.Column="1"
                                                    Spacing="1"
                                                    MinWidth="0">
                                            <TextBlock Text="{Binding DisplayTitle}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding SourceName}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Top"
                                                Command="{Binding DataContext.RemoveContextCommand, ElementName=Root}"
                                                CommandParameter="{Binding}"
                                                ToolTipService.ToolTip="Remove context"
                                                AutomationProperties.Name="Remove context">
                                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                                      Glyph="&#xE711;"
                                                      FontSize="12" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="1"
                        Margin="0,0,0,8"
                        Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                        BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="10"
                        Visibility="{Binding HasModuleSuggestion, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ModuleSuggestionMessage}"
                                   TextWrapping="Wrap"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                        <Button Grid.Column="1"
                                Content="{Binding ModuleSuggestionOpenLabel}"
                                Command="{Binding OpenSuggestedModuleCommand}" />
                        <Button Grid.Column="2"
                                Style="{StaticResource PersonalAiCompactIconButtonStyle}"
                                Command="{Binding DismissModuleSuggestionCommand}"
                                ToolTipService.ToolTip="Dismiss suggestion"
                                AutomationProperties.Name="Dismiss module suggestion">
                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE711;"
                                      FontSize="12" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="2"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="{StaticResource CompactControlPadding}"
                            HorizontalAlignment="Left"
                            Visibility="{Binding IsEditorConnected, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTipService.ToolTip="VS Code integration connected"
                            AutomationProperties.Name="VS Code integration connected">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE943;"
                                      FontSize="12" />
                            <TextBlock Text="VS Code"
                                       Style="{ThemeResource PersonalAiPillTextStyle}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding AttachedContextCount}"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <TextBlock Text="attached"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <Button Command="{Binding ClearAllContextsCommand}"
                                Content="Clear all"
                                Visibility="{Binding HasAttachedContexts, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3"
                      MinWidth="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource PersonalAiIconButtonStyle}"
                            Margin="0,0,12,0"
                            VerticalAlignment="Bottom"
                            ToolTipService.ToolTip="Add context"
                            AutomationProperties.Name="Add context">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE898;"
                                  FontSize="16" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Capture active app"
                                                Command="{Binding CaptureApplicationContextCommand}"
                                                AutomationProperties.Name="Capture active app">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE8B7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Attach clipboard text"
                                                Command="{Binding AttachClipboardContextCommand}"
                                                AutomationProperties.Name="Attach clipboard text">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE8C8;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Capture screenshot"
                                                Command="{Binding CaptureScreenshotContextCommand}"
                                                AutomationProperties.Name="Capture screenshot">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE722;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <TextBox x:Name="PromptTextBox"
                             Grid.Column="1"
                             AcceptsReturn="True"
                             MinWidth="360"
                             MinHeight="84"
                             MaxHeight="160"
                             CornerRadius="14"
                             BorderThickness="0"
                             Background="Transparent"
                             PlaceholderText="Ask anything"
                             Text="{Binding Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Style="{StaticResource PersonalAiPrimaryIconButtonStyle}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding SendMessageCommand}"
                            ToolTipService.ToolTip="Send"
                            AutomationProperties.Name="Send">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE74A;"
                                  FontSize="15" />
                    </Button>
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsTaskCenterVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <StackPanel MinWidth="0"
                                DataContext="{Binding TaskCenter}">
                        <TextBlock Text="Task Center"
                                   Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding SafeStatusMessage}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Command="{Binding TaskCenter.RefreshCommand}"
                                Content="Refresh"
                                ToolTipService.ToolTip="Refresh Task Center" />
                        <Button Command="{Binding OpenDashboardCommand}"
                                Content="Dashboard" />
                        <Button Command="{Binding OpenChatCommand}"
                                Content="Chat" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,20,0,0"
                  DataContext="{Binding TaskCenter}"
                  ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer>
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource PillCornerRadius}"
                                    Padding="{StaticResource CompactControlPadding}">
                                <TextBlock Text="{Binding ActiveTaskCountText}"
                                           Style="{ThemeResource PersonalAiPillTextStyle}" />
                            </Border>
                            <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource PillCornerRadius}"
                                    Padding="{StaticResource CompactControlPadding}">
                                <TextBlock Text="{Binding WaitingApprovalCountText}"
                                           Style="{ThemeResource PersonalAiPillTextStyle}" />
                            </Border>
                            <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource PillCornerRadius}"
                                    Padding="{StaticResource CompactControlPadding}">
                                <TextBlock Text="{Binding RecentFailureCountText}"
                                           Style="{ThemeResource PersonalAiPillTextStyle}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Waiting for Approval"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No approvals need attention."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoWaitingApprovals, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding WaitingApprovals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding SafeSummary}"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2" />
                                                <TextBlock Text="{Binding Module.Label}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Active Tasks"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No active tasks."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoActiveTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding ActiveTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.TaskCenter.SelectTaskCommand, ElementName=Root}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                    BorderThickness="1"
                                                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                    CornerRadius="{StaticResource CardCornerRadius}"
                                                    Padding="{StaticResource CardPadding}"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SafeSummary}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Module.Label}"
                                                               Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Recent Tasks"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No recent task history."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoRecentTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding RecentTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.TaskCenter.SelectTaskCommand, ElementName=Root}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                    BorderThickness="1"
                                                    Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                    CornerRadius="{StaticResource CardCornerRadius}"
                                                    Padding="{StaticResource CardPadding}"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Status.Label}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                    <TextBlock Text="{Binding Module.Label}"
                                                               Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Failed or Cancelled"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No recent failures or cancellations."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoFailedOrCancelledTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding FailedOrCancelledTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding SafeSummary}"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Module.Label}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1"
                        Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                        BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="{StaticResource CardPadding}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedTask.Title}"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedTask.SafeSummary}"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="1"
                                      Margin="0,12,0,0">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Select a task to view timeline."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoTimeline, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding TimelineGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="8"
                                                        Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                <ItemsControl ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                                    BorderThickness="1"
                                                                    Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                                                    CornerRadius="{StaticResource CardCornerRadius}"
                                                                    Padding="{StaticResource CardPadding}"
                                                                    Margin="0,0,0,8">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                                                   TextWrapping="NoWrap"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Status.Label}"
                                                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding Summary}"
                                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                                               TextWrapping="Wrap"
                                                                               MaxLines="2" />
                                                                    <TextBlock Text="{Binding Detail}"
                                                                               Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                                               TextWrapping="Wrap"
                                                                               MaxLines="2" />
                                                                    <ItemsControl ItemsSource="{Binding Links}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding Label}"
                                                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                                                           TextWrapping="NoWrap"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsResearchVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer>
                <StackPanel DataContext="{Binding AedaResearch}"
                            Spacing="14"
                            MinWidth="0">
                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                        <StackPanel Spacing="10"
                                    MinWidth="0">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel MinWidth="0">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                                    <TextBlock Text="{Binding ShortDescription}"
                                               TextWrapping="Wrap"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                        BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource PillCornerRadius}"
                                        Padding="{StaticResource CompactControlPadding}">
                                    <TextBlock Text="{Binding AvailabilityLabel}"
                                               Style="{ThemeResource PersonalAiPillTextStyle}" />
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding PrivacyStatusText}"
                                       TextWrapping="Wrap"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                            <ItemsControl ItemsSource="{Binding CapabilityBadges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource PillCornerRadius}"
                                                Padding="{StaticResource CompactControlPadding}"
                                                Margin="0,0,6,6">
                                            <TextBlock Text="{Binding}"
                                                       Style="{ThemeResource PersonalAiPillTextStyle}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding ProviderStatuses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    Margin="0,0,0,4">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding SafeStatusCode}"
                                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Verification"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBox Header="Text to verify"
                                     PlaceholderText="Paste an answer or factual claim"
                                     AcceptsReturn="True"
                                     MinHeight="110"
                                     MaxHeight="180"
                                     TextWrapping="Wrap"
                                     Text="{Binding VerificationText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="Research verification input" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Extract claims"
                                        Command="{Binding ExtractClaimsCommand}"
                                        ToolTipService.ToolTip="Extract candidate claims without remote calls" />
                                <Button Content="Verify with local evidence"
                                        Command="{Binding VerifyWithLocalEvidenceCommand}"
                                        ToolTipService.ToolTip="Create a local-only verification report" />
                                <TextBlock Text="{Binding SafeStatusMessage}"
                                           VerticalAlignment="Center"
                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                            </StackPanel>
                            <TextBlock Text="No claims extracted."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoClaims, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding ExtractedClaims}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="10"
                                                Margin="0,0,0,6">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Text}"
                                                           TextWrapping="Wrap"
                                                           MaxLines="3" />
                                                <TextBlock Text="{Binding Kind}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Recent reports"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="No verification reports yet."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoRecentReports, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding RecentReports}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.AedaResearch.SelectReportCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,6">
                                                <StackPanel HorizontalAlignment="Stretch"
                                                            MinWidth="0">
                                                    <TextBlock Text="{Binding OverallVerdict}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Question.Text}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10"
                                        MinWidth="0">
                                <TextBlock Text="Report details"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="{Binding SelectedReport.Question.Text}"
                                           TextWrapping="Wrap"
                                           MaxLines="4"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <TextBlock Text="{Binding SelectedReport.OverallVerdict}"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{Binding SelectedReport.Confidence}"
                                               Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                </StackPanel>
                                <TextBlock Text="Evidence"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <ItemsControl ItemsSource="{Binding EvidenceItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="2"
                                                        Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Excerpt}"
                                                           TextWrapping="Wrap"
                                                           MaxLines="3" />
                                                <TextBlock Text="{Binding Source.Label}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Citations"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <ItemsControl ItemsSource="{Binding Citations}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SourceLabel}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Unresolved gaps"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <ItemsControl ItemsSource="{Binding UnresolvedGaps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       TextWrapping="Wrap"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsMemoryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <StackPanel MinWidth="0"
                                DataContext="{Binding AedaMemory}">
                        <TextBlock Text="{Binding DisplayName}"
                                   Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding PrivacyStatusText}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Command="{Binding OpenDashboardCommand}"
                                Content="Dashboard" />
                        <Button Command="{Binding OpenChatCommand}"
                                Content="Chat" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0">
                <StackPanel x:Name="MemorySurface"
                            DataContext="{Binding AedaMemory}"
                            Spacing="20">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource PillCornerRadius}"
                                Padding="{StaticResource CompactControlPadding}">
                            <TextBlock Text="{Binding AvailabilityLabel}"
                                       Style="{ThemeResource PersonalAiPillTextStyle}" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding CapabilityBadges}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource PillCornerRadius}"
                                            Padding="{StaticResource CompactControlPadding}"
                                            Margin="0,0,8,0">
                                        <TextBlock Text="{Binding}"
                                                   Style="{ThemeResource PersonalAiPillTextStyle}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Overview"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="{Binding TotalMemoryCountText}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{Binding IndexedKnowledgeText}"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                            <TextBlock Text="{Binding RetrievalStatusText}"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                            <ItemsControl ItemsSource="{Binding CountSummaries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Add memory"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBox PlaceholderText="Explicit memory"
                                     Text="{Binding NewMemoryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     MinHeight="84"
                                     CornerRadius="10"
                                     AutomationProperties.Name="Explicit memory content" />
                            <TextBox PlaceholderText="Source reason"
                                     Text="{Binding NewMemorySourceReason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     CornerRadius="10"
                                     AutomationProperties.Name="Memory source reason" />
                            <Button Content="Add memory"
                                    Command="{Binding CreateExplicitMemoryCommand}"
                                    ToolTipService.ToolTip="Save only this explicit memory" />
                            <TextBlock Text="{Binding SafeStatusMessage}"
                                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    </Border>

                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Search"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="360"
                                         PlaceholderText="Search memories"
                                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Search memories" />
                                <Button Content="Search"
                                        Command="{Binding SearchMemoriesCommand}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    Margin="0,0,0,8">
                                            <Button Content="Open"
                                                    Command="{Binding DataContext.OpenMemoryDetailCommand, ElementName=MemorySurface}"
                                                    CommandParameter="{Binding}" />
                                            <TextBlock Text="{Binding PreviewText}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Retrieval Preview"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBox Width="360"
                                         PlaceholderText="Preview query"
                                         Text="{Binding RetrievalQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Retrieval preview query" />
                                <Button Content="Preview"
                                        Command="{Binding PreviewRetrievalCommand}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding RetrievalPreview}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2"
                                                    Margin="0,0,0,8">
                                            <TextBlock Text="{Binding SourceLabel}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding PreviewText}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="3"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                    </Border>

                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Recent Memories"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No explicit memories yet."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoRecentMemories, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding Dashboard.RecentMemories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding PreviewText}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding SourceLabel}"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Button Content="Open"
                                                            Command="{Binding DataContext.OpenMemoryDetailCommand, ElementName=MemorySurface}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Archive"
                                                            Command="{Binding DataContext.ArchiveMemoryCommand, ElementName=MemorySurface}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Delete"
                                                            Command="{Binding DataContext.DeleteMemoryCommand, ElementName=MemorySurface}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Task Outcomes"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No task outcome memories."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoTaskOutcomes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding Dashboard.RecentTaskOutcomes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PreviewText}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                   Margin="0,0,0,8" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Spacing="8">
                            <TextBlock Text="Indexed Knowledge"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No indexed documents."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoDocuments, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding Dashboard.RecentDocuments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2"
                                                    Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Title}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding RelativePath}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                            <TextBlock Text="{Binding State}"
                                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                    </Border>

                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Source Detail"
                                   Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                        <TextBlock Text="{Binding SelectedMemory.Text}"
                                   TextWrapping="Wrap"
                                   MaxLines="5"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedMemory.Source.DisplayName}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                        <TextBlock Text="{Binding SelectedMemory.Source.RelativePath}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                        <TextBlock Text="{Binding SelectedMemory.Source.Excerpt}"
                                   TextWrapping="Wrap"
                                   MaxLines="4"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                    </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsDashboardVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <StackPanel MinWidth="0">
                        <TextBlock Text="Module Dashboard"
                                   Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding ModuleDashboard.CurrentWorkspaceSummary}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Command="{Binding OpenChatCommand}"
                            Content="Back to chat" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0">
                <StackPanel DataContext="{Binding ModuleDashboard}"
                            Spacing="20">
                    <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Padding="{StaticResource CardPadding}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                        BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource PillCornerRadius}"
                                        Padding="{StaticResource CompactControlPadding}">
                                    <TextBlock Text="{Binding DataContext.TaskCenter.ActiveTaskCountText, ElementName=Root}"
                                               Style="{ThemeResource PersonalAiPillTextStyle}" />
                                </Border>
                                <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                        BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource PillCornerRadius}"
                                        Padding="{StaticResource CompactControlPadding}">
                                    <TextBlock Text="{Binding DataContext.TaskCenter.WaitingApprovalCountText, ElementName=Root}"
                                               Style="{ThemeResource PersonalAiPillTextStyle}" />
                                </Border>
                                <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                        BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource PillCornerRadius}"
                                        Padding="{StaticResource CompactControlPadding}">
                                    <TextBlock Text="{Binding DataContext.TaskCenter.RecentFailureCountText, ElementName=Root}"
                                               Style="{ThemeResource PersonalAiPillTextStyle}" />
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding DataContext.OpenTaskCenterCommand, ElementName=Root}"
                                    Content="Task Center" />
                        </Grid>
                    </Border>

                    <GridView ItemsSource="{Binding ModuleTiles}"
                              SelectionMode="None"
                              IsItemClickEnabled="False"
                              HorizontalAlignment="Stretch">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,16,16" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                               MaximumRowsOrColumns="3" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Button Width="240"
                                        MinHeight="180"
                                        Style="{StaticResource PersonalAiTileButtonStyle}"
                                        Command="{Binding OpenCommand}"
                                        IsEnabled="{Binding IsEnabled}"
                                        ToolTipService.ToolTip="{Binding ToolTipText}"
                                        AutomationProperties.Name="{Binding AccessibleName}">
                                    <Border BorderBrush="{Binding DisplayName, Converter={StaticResource ModuleAccentBorderConverter}}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource CardCornerRadius}"
                                            Background="{Binding DisplayName, Converter={StaticResource ModuleAccentFillConverter}}"
                                            Padding="{StaticResource CardPadding}"
                                            Width="240"
                                            MinHeight="180">
                                        <StackPanel Spacing="8">
                                            <Grid>
                                                <Border Width="34"
                                                        Height="34"
                                                        CornerRadius="{StaticResource IconContainerCornerRadius}"
                                                        Background="#1AFFFFFF"
                                                        HorizontalAlignment="Left">
                                                    <FontIcon FontFamily="Segoe MDL2 Assets"
                                                              Glyph="{Binding Glyph}"
                                                              FontSize="17"
                                                              Foreground="{Binding DisplayName, Converter={StaticResource ModuleAccentForegroundConverter}}" />
                                                </Border>
                                                <Border HorizontalAlignment="Right"
                                                        Background="#1AFFFFFF"
                                                        BorderThickness="0"
                                                        CornerRadius="{StaticResource PillCornerRadius}"
                                                        Padding="{StaticResource CompactControlPadding}">
                                                    <TextBlock Text="{Binding StatusLabel}"
                                                               Style="{ThemeResource PersonalAiPillTextStyle}"
                                                               Foreground="{Binding DisplayName, Converter={StaticResource ModuleAccentForegroundConverter}}" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ShortDescription}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="3"
                                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                            <TextBlock Text="{Binding CapabilityHintText}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            <TextBlock Text="{Binding SafeUnavailableReason}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       Style="{ThemeResource PersonalAiMetadataTextStyle}"
                                                       Visibility="{Binding HasUnavailableReason, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Active Tasks"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No active tasks"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoActiveTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding ActiveTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding SafeSummary}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                <TextBlock Text="{Binding UpdatedAt}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Recent Tasks"
                                       Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                            <TextBlock Text="No recent tasks"
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoRecentTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding RecentTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding SafeSummary}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                <TextBlock Text="{Binding UpdatedAt}"
                                                           Style="{ThemeResource PersonalAiMetadataTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="1"
              Padding="{StaticResource PagePadding}"
              Background="{ThemeResource PersonalAiPageBackgroundBrush}"
              Visibility="{Binding IsCodeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardPadding}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel MinWidth="0"
                                DataContext="{Binding AedaCode}">
                        <TextBlock Text="{Binding DisplayName}"
                                   Style="{ThemeResource PersonalAiPageTitleTextStyle}" />
                        <TextBlock Text="{Binding WorkspaceSummary}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SafeStatusMessage}"
                                   Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Command="{Binding AedaCode.RefreshCommand}"
                                Content="Refresh"
                                AutomationProperties.Name="Refresh AEDA Code workflow" />
                        <Button Command="{Binding OpenTaskCenterCommand}"
                                Content="Task Center" />
                        <Button Command="{Binding OpenDashboardCommand}"
                                Content="Dashboard" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="0,20,0,0"
                          HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Auto">
                <Grid DataContext="{Binding AedaCode}"
                      ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="AedaCodeWorkspaceColumn"
                                          Width="280" />
                        <ColumnDefinition x:Name="AedaCodeMainColumn"
                                          Width="*"
                                          MinWidth="380" />
                        <ColumnDefinition x:Name="AedaCodeWorkflowColumn"
                                          Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup>
                            <VisualState x:Name="AedaCodeNarrowLayout" />
                            <VisualState x:Name="AedaCodeWideLayout">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="1450" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="AedaCodeMainColumn.MinWidth"
                                            Value="560" />
                                    <Setter Target="AedaCodeWorkflowColumn.Width"
                                            Value="340" />
                                    <Setter Target="AedaCodeNarrowWorkflowPanel.Visibility"
                                            Value="Collapsed" />
                                    <Setter Target="AedaCodeWideWorkflowPanel.Visibility"
                                            Value="Visible" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <StackPanel Grid.RowSpan="2"
                                Spacing="16">
                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Workspace"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="{Binding SessionStatusText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding RecentCodeTaskCountText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                <TextBlock Text="No registered workspaces."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoWorkspaces, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding Workspaces}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectWorkspaceCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    Margin="0,0,0,8"
                                                    AutomationProperties.Name="{Binding DisplayName}">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                    <TextBlock Text="{Binding RootSummary}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding PolicyLabel}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="Start session"
                                        Command="{Binding StartSessionCommand}"
                                        HorizontalAlignment="Stretch"
                                        ToolTipService.ToolTip="Start a supervised AEDA Code session for the selected registered workspace." />
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Proposals"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="{Binding ProposalCountText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                <TextBlock Text="No proposals for this workspace."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoProposals, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding Proposals}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectProposalCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    Margin="0,0,0,8"
                                                    AutomationProperties.Name="{Binding Title}">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{Binding Title}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                    <TextBlock Text="{Binding SafeSummary}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Style="{ThemeResource PersonalAiSecondaryTextStyle}">
                                                        <Run Text="{Binding Status}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding RiskLabel}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding AffectedFileCount}" />
                                                        <Run Text=" files" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding UpdatedText}"
                                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Grid.Row="0"
                                Spacing="16">
                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Proposal Detail"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="Select a proposal to inspect safe detail and diff."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoSelectedProposal, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock Text="{Binding SelectedProposal.Title}"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{Binding SelectedProposal.SafeSummary}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding RiskSummary}"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding HashStatusText}"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding AffectedFileCountText}"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SourceSummaryText}"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding ProposalFiles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                                                    BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource PillCornerRadius}"
                                                    Padding="{StaticResource CompactControlPadding}"
                                                    Margin="0,0,0,6">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding RelativePath}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Style="{ThemeResource PersonalAiSecondaryTextStyle}">
                                                        <Run Text="{Binding ChangeKind}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding OriginalHashStatus}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding ProposedHashStatus}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Unified Diff"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBox Text="{Binding UnifiedDiffPreview, Mode=OneWay}"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         TextWrapping="NoWrap"
                                         FontFamily="Consolas"
                                         MinHeight="360"
                                         MaxHeight="620"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         AutomationProperties.Name="Unified diff preview" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="AedaCodeNarrowWorkflowPanel"
                                Grid.Column="1"
                                Grid.Row="1"
                                Spacing="16">
                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Review Gates"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="{Binding ValidationPlanText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding DryRunStatusText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <Button Content="Dry run"
                                        Command="{Binding DryRunSelectedProposalCommand}"
                                        HorizontalAlignment="Stretch" />
                                <TextBlock Text="{Binding ApplyApprovalStatusText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <Button Content="Request apply approval"
                                        Command="{Binding RequestApplyApprovalCommand}"
                                        HorizontalAlignment="Stretch" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Allow once"
                                            Command="{Binding AllowApplyOnceCommand}"
                                            HorizontalAlignment="Stretch" />
                                    <Button Grid.Column="1"
                                            Content="Deny"
                                            Command="{Binding DenyApplyApprovalCommand}"
                                            HorizontalAlignment="Stretch" />
                                </Grid>
                                <Button Content="Apply approved proposal"
                                        Command="{Binding ApplyApprovedProposalCommand}"
                                        HorizontalAlignment="Stretch" />
                                <TextBlock Text="{Binding ApplyResultText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <Button Content="Rollback apply result"
                                        Command="{Binding RollbackSelectedApplyResultCommand}"
                                        HorizontalAlignment="Stretch"
                                        ToolTipService.ToolTip="Rollback is available only after an apply result with backups." />
                                <TextBlock Text="{Binding RollbackStatusText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Validation"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="No allowlisted validation templates available."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoValidationTemplates, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ComboBox ItemsSource="{Binding ValidationTemplates}"
                                          SelectedItem="{Binding SelectedValidationTemplate, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          HorizontalAlignment="Stretch"
                                          AutomationProperties.Name="Validation template" />
                                <TextBlock Text="{Binding SelectedValidationTemplate.SafeCommandSummary}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <Button Content="Create validation run"
                                        Command="{Binding CreateValidationRunCommand}"
                                        HorizontalAlignment="Stretch" />
                                <TextBlock Text="{Binding ValidationApprovalStatusText}"
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           TextWrapping="Wrap" />
                                <Button Content="Request validation approval"
