                            <StackPanel Spacing="10">
                                <TextBlock Text="Code Timeline"
                                           Style="{ThemeResource PersonalAiSectionTitleTextStyle}" />
                                <TextBlock Text="No recent Code tasks."
                                           Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                           Visibility="{Binding HasNoRecentCodeTasks, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding RecentCodeTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectTaskCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
