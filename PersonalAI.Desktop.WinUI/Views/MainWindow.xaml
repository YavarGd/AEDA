                                             Text="{Binding PendingFolderPath}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap" />
                                    <TextBox Header="Display name"
                                             Text="{Binding PendingDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Workspace tools may request permission to read files in this folder. Current workspace tools are read-only and cannot change files. Symlinks and junctions are rejected."
                                               TextWrapping="Wrap"
                                               Style="{ThemeResource PersonalAiSecondaryTextStyle}" />
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="Add workspace"
                                                Command="{Binding AddPendingWorkspaceCommand}" />
                                        <Button Content="Cancel"
                                                Command="{Binding CancelPendingWorkspaceCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="No workspaces registered."
                                       Style="{ThemeResource PersonalAiSecondaryTextStyle}"
                                       Visibility="{Binding HasNoWorkspaces, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Workspaces}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                                                CornerRadius="{StaticResource CardCornerRadius}"
                                                Padding="{StaticResource CardPadding}"
