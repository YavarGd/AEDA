<Window
    x:Class="PersonalAI.Desktop.WinUI.Views.AssistPillWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters">

    <Grid x:Name="Root"
          Background="Transparent"
          KeyDown="Root_KeyDown">
        <Grid.Resources>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </Grid.Resources>

        <Border Width="64"
                Height="64"
                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                BorderBrush="{ThemeResource PersonalAiStrongBorderBrush}"
                BorderThickness="1"
                CornerRadius="32"
                Visibility="{Binding IsIdle, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Button Margin="6"
                        Padding="0"
                        Width="52"
                        Height="52"
                        MinWidth="0"
                        MinHeight="0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        AutomationProperties.Name="Open AEDA Assist"
                        Background="{ThemeResource PersonalAiAccentBrush}"
                        BorderThickness="0"
                        Click="OpenPromptButton_Click"
                        CornerRadius="26"
                        ToolTipService.ToolTip="Open AEDA Assist">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="A" />
                </Button>
                <Rectangle Height="6" VerticalAlignment="Top" Fill="Transparent"
                           PointerPressed="IdleDragRegion_PointerPressed" />
                <Rectangle Height="6" VerticalAlignment="Bottom" Fill="Transparent"
                           PointerPressed="IdleDragRegion_PointerPressed" />
                <Rectangle Width="6" HorizontalAlignment="Left" Fill="Transparent"
                           PointerPressed="IdleDragRegion_PointerPressed" />
                <Rectangle Width="6" HorizontalAlignment="Right" Fill="Transparent"
                           PointerPressed="IdleDragRegion_PointerPressed" />
            </Grid>
        </Border>

        <Border Margin="1"
                Padding="14"
                Opacity="0.96"
                Background="{ThemeResource PersonalAiElevatedSurfaceBrush}"
                BorderBrush="{ThemeResource PersonalAiStrongBorderBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28"
                            Background="{ThemeResource PersonalAiAccentBrush}"
                            CornerRadius="14">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="A" />
                    </Border>
                    <Grid x:Name="ExpandedDragRegion"
                          Grid.Column="1"
                          Margin="10,0"
                          PointerPressed="DragRegion_PointerPressed">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource PersonalAiPrimaryTextBrush}"
                                       Text="AEDA Assist" />
                            <ProgressRing Width="14"
                                          Height="14"
                                          IsActive="{Binding IsStreaming}"
                                          Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Grid>
                    <Button Grid.Column="2"
                            Margin="0,0,4,0"
                            Click="CollapseButton_Click"
                            AutomationProperties.Name="Collapse AEDA Assist"
                            Content="—"
                            ToolTipService.ToolTip="Collapse" />
                    <Button Grid.Column="3"
                            Click="CloseButton_Click"
                            AutomationProperties.Name="Hide AEDA Assist"
                            Content="×"
                            ToolTipService.ToolTip="Hide" />
                </Grid>

                <Grid Grid.Row="1"
                      Visibility="{Binding IsFallbackInput, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PromptTextBox"
                             MinHeight="44"
                             Padding="12,9"
                             AcceptsReturn="False"
                             AutomationProperties.Name="AEDA Assist prompt"
                             KeyDown="PromptTextBox_KeyDown"
                             PlaceholderText="Ask AEDA…"
                             Text="{Binding Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Width="42"
                            Height="42"
                            MinWidth="0"
                            Margin="8,0,0,0"
                            Command="{Binding SubmitCommand}"
                            AutomationProperties.Name="Submit AEDA Assist request"
                            ToolTipService.ToolTip="Submit">
                        <FontIcon Glyph="&#xE74A;" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1"
                      Visibility="{Binding IsResponseSurface, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock AutomationProperties.LiveSetting="Polite"
                               Foreground="{ThemeResource PersonalAiMutedTextBrush}"
                               Text="{Binding StatusText}"
                               TextTrimming="CharacterEllipsis" />
                    <Border Grid.Row="1"
                            Margin="0,6,0,0"
                            Padding="12"
                            Background="{ThemeResource PersonalAiSubtleSurfaceBrush}"
                            BorderBrush="{ThemeResource PersonalAiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock AutomationProperties.LiveSetting="Polite"
                                       Foreground="{ThemeResource PersonalAiPrimaryTextBrush}"
                                       Text="{Binding Response}"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Command="{Binding CancelCommand}"
                            AutomationProperties.Name="Stop AEDA Assist response"
                            Content="Stop"
                            Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Command="{Binding CopyResponseCommand}"
                            AutomationProperties.Name="Copy AEDA Assist response"
                            Content="Copy"
                            Visibility="{Binding CanShowResponseActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Command="{Binding OpenInAedaCommand}"
                            AutomationProperties.Name="Open response in AEDA"
                            Content="Open in AEDA"
                            Visibility="{Binding CanShowResponseActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
