<Window
    x:Class="PersonalAI.Desktop.WinUI.Views.AssistPillWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PersonalAI.Desktop.WinUI.Converters">

    <Grid x:Name="Root"
          Background="Transparent"
          KeyDown="Root_KeyDown">
        <Grid.Resources>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </Grid.Resources>

        <Border x:Name="IdleSurface"
                Width="64"
                Height="64"
                Background="{ThemeResource AedaAssistIdleBrush}"
                BorderBrush="{ThemeResource AedaAssistBorderBrush}"
                BorderThickness="1"
                CornerRadius="32"
                Visibility="{Binding IsIdle, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Button x:Name="LauncherButton"
                        Margin="6"
                        Padding="0"
                        Width="52"
                        Height="52"
                        MinWidth="0"
                        MinHeight="0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        AutomationProperties.Name="Open AEDA Assist"
                        Click="OpenPromptButton_Click"
                        PointerCanceled="LauncherButton_PointerReleased"
                        PointerCaptureLost="LauncherButton_PointerReleased"
                        PointerExited="LauncherButton_PointerReleased"
                        PointerPressed="LauncherButton_PointerPressed"
                        PointerReleased="LauncherButton_PointerReleased"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource AedaAssistLauncherButtonStyle}"
                        ToolTipService.ToolTip="Open AEDA Assist">
                    <Button.RenderTransform>
                        <ScaleTransform x:Name="LauncherScale" ScaleX="1" ScaleY="1" />
                    </Button.RenderTransform>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="A" />
                </Button>
                <Rectangle Height="6" VerticalAlignment="Top" Fill="Transparent"
                           PointerPressed="IdleDragRegion_PointerPressed" />
                <Rectangle Height="6" VerticalAlignment="Bottom" Fill="Transparent"
                           PointerPressed="IdleDragRegion_PointerPressed" />
                <Rectangle Width="6" HorizontalAlignment="Left" Fill="Transparent"
                           PointerPressed="IdleDragRegion_PointerPressed" />
                <Rectangle Width="6" HorizontalAlignment="Right" Fill="Transparent"
                           PointerPressed="IdleDragRegion_PointerPressed" />
            </Grid>
        </Border>

        <Border x:Name="SelectionFallbackSurface"
                Margin="1"
                Padding="16"
                Background="{ThemeResource AedaAssistSpotlightBrush}"
                BorderBrush="{ThemeResource AedaAssistBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource AedaAssistCornerRadius}"
                Shadow="{StaticResource AedaAssistShadow}"
                Translation="0,0,8"
                Visibility="{Binding IsSelectionFallback, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Spacing="12">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource AedaAssistForegroundBrush}"
                           Text="{Binding StatusText}"
                           TextWrapping="Wrap" />
                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button x:Name="SelectScreenTextButton"
                            Click="SelectScreenTextButton_Click"
                            AutomationProperties.Name="Select text from a screen region"
                            Content="{Binding ScreenSelectionActionText}" />
                    <Button Command="{Binding TypeManuallyCommand}"
                            AutomationProperties.Name="Type an AEDA Assist prompt manually"
                            Content="Type manually" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name="SpotlightSurface"
                Margin="1"
                Padding="8"
                Background="{ThemeResource AedaAssistSpotlightBrush}"
                BorderBrush="{ThemeResource AedaAssistBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource AedaAssistCornerRadius}"
                Shadow="{StaticResource AedaAssistShadow}"
                Translation="0,0,8"
                Visibility="{Binding IsFallbackInput, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <TextBox x:Name="PromptTextBox"
                         MinHeight="44"
                         Padding="12,9,52,9"
                         AcceptsReturn="False"
                         AutomationProperties.Name="AEDA Assist prompt"
                         KeyDown="PromptTextBox_KeyDown"
                         PlaceholderText="Ask AEDA…"
                         Text="{Binding Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Width="42"
                        Height="42"
                        MinWidth="0"
                        Margin="0,1,1,1"
                        HorizontalAlignment="Right"
                        Command="{Binding SubmitCommand}"
                        AutomationProperties.Name="Submit AEDA Assist request"
                        ToolTipService.ToolTip="Submit">
                    <FontIcon Glyph="&#xE74A;" />
                </Button>
            </Grid>
        </Border>

        <Border x:Name="ResponseCard"
                Margin="1"
                Padding="14"
                Background="{ThemeResource AedaAssistResponseBrush}"
                BorderBrush="{ThemeResource AedaAssistBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource AedaAssistCornerRadius}"
                Shadow="{StaticResource AedaAssistShadow}"
                Translation="0,0,8"
                Visibility="{Binding IsResponseSurface, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28"
                            Background="{ThemeResource PersonalAiAccentBrush}"
                            CornerRadius="14">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="A" />
                    </Border>
                    <Grid x:Name="ExpandedDragRegion"
                          Grid.Column="1"
                          Margin="10,0"
                          PointerPressed="DragRegion_PointerPressed">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource AedaAssistForegroundBrush}"
                                       Text="AEDA Assist" />
                            <ProgressRing Width="14"
                                          Height="14"
                                          IsActive="{Binding IsStreaming}"
                                          Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Grid>
                    <Button Grid.Column="2"
                            Margin="0,0,4,0"
                            Style="{StaticResource AedaAssistActionButtonStyle}"
                            Click="CollapseButton_Click"
                            AutomationProperties.Name="Collapse AEDA Assist"
                            ToolTipService.ToolTip="Collapse">
                        <FontIcon FontSize="12" Glyph="&#xE70D;" />
                    </Button>
                    <Button Grid.Column="3"
                            Style="{StaticResource AedaAssistActionButtonStyle}"
                            Click="CloseButton_Click"
                            AutomationProperties.Name="Hide AEDA Assist"
                            ToolTipService.ToolTip="Hide">
                        <FontIcon FontSize="12" Glyph="&#xE8BB;" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1"
                      Visibility="{Binding IsResponseSurface, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock AutomationProperties.LiveSetting="Polite"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               Foreground="{ThemeResource AedaAssistSecondaryForegroundBrush}"
                               Text="{Binding StatusText}"
                               TextTrimming="CharacterEllipsis" />
                    <ScrollViewer x:Name="ResponseScrollViewer"
                                  Grid.Row="1"
                                  Margin="0,8,0,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Auto"
                                  ViewChanged="ResponseScrollViewer_ViewChanged">
                        <TextBlock x:Name="ResponsePresenter"
                                   AutomationProperties.Name="AEDA Assist response"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="15"
                                   Foreground="{ThemeResource AedaAssistForegroundBrush}"
                                   IsTextSelectionEnabled="True"
                                   LineHeight="22"
                                   LineStackingStrategy="BlockLineHeight"
                                   Text="{Binding Response}"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>

                <StackPanel Grid.Row="2"
                            HorizontalAlignment="Right"
                            MinHeight="32"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Command="{Binding CancelCommand}"
                            Style="{StaticResource AedaAssistActionButtonStyle}"
                            AutomationProperties.Name="Stop AEDA Assist response"
                            Content="Stop"
                            Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Command="{Binding RetryCommand}"
                            Style="{StaticResource AedaAssistActionButtonStyle}"
                            AutomationProperties.Name="Retry AEDA Assist request"
                            Content="Retry"
                            Visibility="{Binding CanRetry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Command="{Binding CopyResponseCommand}"
                            Style="{StaticResource AedaAssistActionButtonStyle}"
                            AutomationProperties.Name="Copy AEDA Assist response"
                            Content="Copy"
                            Visibility="{Binding CanShowResponseActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Command="{Binding OpenInAedaCommand}"
                            Style="{StaticResource AedaAssistActionButtonStyle}"
                            AutomationProperties.Name="Open response in AEDA"
                            Content="Open in AEDA"
                            Visibility="{Binding CanShowResponseActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
