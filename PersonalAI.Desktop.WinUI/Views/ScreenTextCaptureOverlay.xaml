<Window
    x:Class="PersonalAI.Desktop.WinUI.Views.ScreenTextCaptureOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="Root"
          Background="Black"
          IsTabStop="True"
          KeyDown="Root_KeyDown"
          PointerCanceled="Root_PointerCanceled"
          PointerEntered="Root_PointerEntered"
          PointerMoved="Root_PointerMoved"
          PointerPressed="Root_PointerPressed"
          PointerReleased="Root_PointerReleased"
          RightTapped="Root_RightTapped">
        <Image x:Name="BackgroundImage" Stretch="Fill" />
        <Canvas IsHitTestVisible="False">
            <Rectangle x:Name="TopShade" Fill="#99000000" />
            <Rectangle x:Name="BottomShade" Fill="#99000000" />
            <Rectangle x:Name="LeftShade" Fill="#99000000" />
            <Rectangle x:Name="RightShade" Fill="#99000000" />
            <Border x:Name="SelectionBorder"
                    BorderBrush="#FF6FD8FF"
                    BorderThickness="2"
                    CornerRadius="3"
                    Visibility="Collapsed" />
        </Canvas>
        <Border Margin="0,28,0,0"
                Padding="14,8"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="#D9202020"
                CornerRadius="8"
                IsHitTestVisible="False">
            <TextBlock Foreground="White"
                       Text="Drag around text - Esc to cancel" />
        </Border>
    </Grid>
</Window>
